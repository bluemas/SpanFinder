<UserControl
    x:Class="Span.Views.PreviewPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:Span.Helpers"
    Background="Transparent">

    <UserControl.Resources>
        <helpers:VisibilityConverter x:Key="VisConv"/>
    </UserControl.Resources>

    <Grid x:Name="RootPanel" Background="{ThemeResource SpanBgLayer1Brush}">
        <!-- Loading indicator -->
        <ProgressBar IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource VisConv}}"
                     VerticalAlignment="Top" HorizontalAlignment="Stretch"/>

        <!-- Empty state -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding HasContent, Converter={StaticResource VisConv}, ConverterParameter=Invert}">
            <FontIcon Glyph="&#xE8A5;" FontSize="32"
                      Foreground="{ThemeResource SpanTextTertiaryBrush}"
                      HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock x:Name="EmptyStateText" Text="파일을 선택하면&#x000a;미리보기가 표시됩니다"
                       TextAlignment="Center" FontSize="13"
                       Foreground="{ThemeResource SpanTextTertiaryBrush}"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Visibility="{Binding HasContent, Converter={StaticResource VisConv}}">
            <StackPanel Padding="16" Spacing="12">

                <!-- Header: Icon + Name -->
                <StackPanel HorizontalAlignment="Center" Spacing="8" Margin="0,8,0,4">
                    <FontIcon FontFamily="{StaticResource RemixIcons}"
                              Glyph="{Binding FileIconGlyph}"
                              Foreground="{Binding FileIconBrush}"
                              FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding FileName}"
                               TextWrapping="Wrap" TextAlignment="Center"
                               FontWeight="SemiBold" FontSize="14"
                               MaxLines="3" TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Image Preview -->
                <Image Source="{Binding ImagePreview}"
                       Visibility="{Binding IsImageVisible, Converter={StaticResource VisConv}}"
                       Stretch="Uniform" MaxHeight="400"
                       HorizontalAlignment="Center"/>

                <!-- Text Preview (Syntax Highlighted) -->
                <Border Visibility="{Binding IsTextVisible, Converter={StaticResource VisConv}}"
                        Background="{ThemeResource SpanBgLayer1Brush}"
                        CornerRadius="4" Padding="8" MaxHeight="300">
                    <ScrollViewer x:Name="CodePreviewScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  MaxHeight="284">
                        <RichTextBlock x:Name="CodePreviewBlock"
                                       FontFamily="{StaticResource MonoFont}" FontSize="11"
                                       TextWrapping="Wrap"
                                       IsTextSelectionEnabled="True"
                                       Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                    </ScrollViewer>
                </Border>

                <!-- PDF Preview -->
                <Image Source="{Binding PdfPreview}"
                       Visibility="{Binding IsPdfVisible, Converter={StaticResource VisConv}}"
                       Stretch="Uniform" MaxHeight="500"
                       HorizontalAlignment="Center"/>

                <!-- Media Preview -->
                <Grid Visibility="{Binding IsMediaVisible, Converter={StaticResource VisConv}}"
                      CornerRadius="4" Background="{ThemeResource SpanBgLayer1Brush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <MediaPlayerElement x:Name="PreviewMediaPlayer" Grid.Row="0"
                                        Source="{Binding MediaSource}"
                                        AreTransportControlsEnabled="False"
                                        IsHitTestVisible="False"
                                        Stretch="Uniform"
                                        AutoPlay="False"
                                        MaxHeight="360"/>

                    <!-- Hit-testable overlay: MediaPlayerElement의 SwapChainPanel이 XAML hit-test를 가로채므로
                         거의 투명한 Background로 포인터 이벤트를 받을 수 있게 함 -->
                    <Grid Grid.Row="0" Background="#01000000">
                        <!-- 중앙 Play 버튼 (정지/일시정지 상태) -->
                        <Button x:Name="CenterPlayButton"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Click="OnCenterPlayClick"
                                Width="48" Height="48"
                                CornerRadius="24"
                                Padding="0"
                                Background="#70000000"
                                BorderThickness="0">
                            <FontIcon x:Name="CenterPlayIcon"
                                      Glyph="&#xE768;" FontSize="20"
                                      Foreground="White"/>
                        </Button>

                        <!-- 하단 컨트롤바 (재생 중에만 표시) -->
                        <Grid x:Name="BottomControlBar"
                              VerticalAlignment="Bottom"
                              Background="#B0000000"
                              Padding="6,4" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Click="OnBottomPauseClick"
                                    Width="28" Height="28" CornerRadius="14"
                                    Padding="0" Background="Transparent" BorderThickness="0">
                                <FontIcon Glyph="&#xE769;" FontSize="14" Foreground="White"/>
                            </Button>
                            <Slider x:Name="SeekSlider" Grid.Column="1"
                                    Margin="6,0" VerticalAlignment="Center"
                                    Minimum="0" Maximum="100" Value="0"
                                    IsHitTestVisible="False"
                                    ThumbToolTipValueConverter="{x:Null}"/>
                            <TextBlock x:Name="TimeLabel" Grid.Column="2"
                                       Text="0:00" FontSize="11" Foreground="White"
                                       VerticalAlignment="Center" MinWidth="32"
                                       TextAlignment="Right"/>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- Hex Binary Preview -->
                <Border Visibility="{Binding IsHexBinaryVisible, Converter={StaticResource VisConv}}"
                        Background="{ThemeResource SpanBgLayer1Brush}"
                        CornerRadius="4" Padding="8" MaxHeight="360">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  MaxHeight="344">
                        <TextBlock Text="{Binding HexPreview}"
                                   FontFamily="{StaticResource MonoFont}" FontSize="10.5"
                                   TextWrapping="NoWrap" LineHeight="16"
                                   IsTextSelectionEnabled="True"
                                   Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                    </ScrollViewer>
                </Border>

                <!-- Font Preview -->
                <StackPanel Visibility="{Binding IsFontVisible, Converter={StaticResource VisConv}}"
                            Spacing="12">
                    <!-- Font format badge -->
                    <Border Background="{ThemeResource SpanBgLayer1Brush}"
                            CornerRadius="4" Padding="6,3" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding FontFormat}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{ThemeResource SpanAccentBrush}"/>
                    </Border>
                    <!-- Sample text in the font itself -->
                    <StackPanel Background="{ThemeResource SpanBgLayer1Brush}"
                                CornerRadius="4" Padding="12" Spacing="8">
                        <TextBlock Text="AaBbCcDdEeFfGgHhIiJjKk" FontSize="24"
                                   FontFamily="{Binding FontFamilySource}"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="{ThemeResource SpanTextPrimaryBrush}"/>
                        <TextBlock Text="0123456789 !@#$%^&amp;*()" FontSize="18"
                                   FontFamily="{Binding FontFamilySource}"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                        <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="0,4"/>
                        <TextBlock Text="다람쥐 헌 쳇바퀴에 타고파" FontSize="20"
                                   FontFamily="{Binding FontFamilySource}"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="{ThemeResource SpanTextPrimaryBrush}"/>
                        <TextBlock Text="The quick brown fox jumps over the lazy dog" FontSize="14"
                                   FontFamily="{Binding FontFamilySource}"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                    </StackPanel>
                    <!-- Size samples -->
                    <StackPanel Background="{ThemeResource SpanBgLayer1Brush}"
                                CornerRadius="4" Padding="12" Spacing="4">
                        <TextBlock Text="12px - Preview" FontSize="12" FontFamily="{Binding FontFamilySource}"
                                   Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                        <TextBlock Text="16px - Preview" FontSize="16" FontFamily="{Binding FontFamilySource}"
                                   Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                        <TextBlock Text="24px - Preview" FontSize="24" FontFamily="{Binding FontFamilySource}"
                                   Foreground="{ThemeResource SpanTextPrimaryBrush}"/>
                        <TextBlock Text="36px - Preview" FontSize="36" FontFamily="{Binding FontFamilySource}"
                                   Foreground="{ThemeResource SpanTextPrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Archive Contents -->
                <StackPanel Visibility="{Binding IsArchiveVisible, Converter={StaticResource VisConv}}"
                            Spacing="8" Margin="0,4,0,0">

                    <!-- Stats row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding ArchiveStats}"
                                   FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="{Binding ArchiveCompressionRatio}"
                                   FontSize="12" Foreground="{ThemeResource SpanAccentBrush}"
                                   FontWeight="SemiBold"/>
                    </Grid>

                    <!-- Size info -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="LabelCompressed" Text="Compressed" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Text="{Binding ArchiveCompressedSize}" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock x:Name="LabelOriginal" Text="Original" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Text="{Binding ArchiveUncompressedSize}" FontSize="13"/>
                        </StackPanel>
                    </Grid>

                    <!-- Content tree -->
                    <Border Background="{ThemeResource SpanBgLayer1Brush}"
                            CornerRadius="4" Padding="10" MaxHeight="300">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding ArchiveContentTree}"
                                       FontSize="12" LineHeight="20"
                                       TextWrapping="NoWrap"
                                       IsTextSelectionEnabled="True"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>

                <!-- Folder Info -->
                <StackPanel Visibility="{Binding IsFolderVisible, Converter={StaticResource VisConv}}"
                            HorizontalAlignment="Center" Spacing="8" Margin="0,8">
                    <FontIcon FontFamily="{StaticResource RemixIcons}"
                              Glyph="{StaticResource Icon_Folder}"
                              FontSize="48"
                              Foreground="{ThemeResource SpanTextTertiaryBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding FolderItemCount}"
                               HorizontalAlignment="Center" FontSize="14"
                               Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                </StackPanel>

                <!-- Separator -->
                <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="0,4"/>

                <!-- Metadata Section -->
                <StackPanel Spacing="2">
                    <!-- File Type -->
                    <Grid Height="24" Visibility="{Binding FileType, Converter={StaticResource VisConv}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LabelType" Text="종류" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding FileType}" FontSize="12" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Size -->
                    <Grid Height="24" Visibility="{Binding FileSizeFormatted, Converter={StaticResource VisConv}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LabelSize" Text="크기" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding FileSizeFormatted}" FontSize="12" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Created -->
                    <Grid Height="24" Visibility="{Binding DateCreated, Converter={StaticResource VisConv}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LabelCreated" Text="생성일" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding DateCreated}" FontSize="12" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Modified -->
                    <Grid Height="24" Visibility="{Binding DateModified, Converter={StaticResource VisConv}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LabelModified" Text="수정일" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding DateModified}" FontSize="12" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Dimensions (conditional) -->
                    <Grid Height="24" Visibility="{Binding Dimensions, Converter={StaticResource VisConv}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LabelResolution" Text="해상도" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Dimensions}" FontSize="12" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Duration (conditional) -->
                    <Grid Height="24" Visibility="{Binding Duration, Converter={StaticResource VisConv}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LabelDuration" Text="재생시간" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Duration}" FontSize="12" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Artist (conditional) -->
                    <Grid Height="24" Visibility="{Binding Artist, Converter={StaticResource VisConv}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LabelArtist" Text="아티스트" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Artist}" FontSize="12" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Album (conditional) -->
                    <Grid Height="24" Visibility="{Binding Album, Converter={StaticResource VisConv}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LabelAlbum" Text="앨범" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Album}" FontSize="12" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- Git: Tier 1 — 파일 마지막 커밋 정보 -->
                <StackPanel Visibility="{Binding HasGitInfo, Converter={StaticResource VisConv}}"
                            Spacing="4">
                    <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}"/>
                    <TextBlock x:Name="LabelGit" Text="Git" FontSize="11" FontWeight="SemiBold"
                               Foreground="{ThemeResource SpanTextTertiaryBrush}" Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding GitLastCommitInfo}"
                               FontSize="12" TextWrapping="Wrap" LineHeight="18"
                               IsTextSelectionEnabled="True"
                               Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
