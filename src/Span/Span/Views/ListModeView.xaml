<UserControl
    x:Class="Span.Views.ListModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Span.ViewModels"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Tapped="OnRootTapped" RightTapped="OnEmptyAreaRightTapped" Background="Transparent">

        <!-- Items GridView with vertical wrapping -->
        <Grid x:Name="ListViewWrapper"
              Loaded="OnListViewWrapperLoaded" Unloaded="OnListViewWrapperUnloaded">
        <GridView x:Name="ListGridView" AutomationProperties.AutomationId="List_GridView"
                  SelectionMode="Extended"
                  CanDragItems="True"
                  AllowDrop="True"
                  DragItemsStarting="OnDragItemsStarting"
                  DragItemsCompleted="OnDragItemsCompleted"
                  DragOver="OnGridViewDragOver"
                  Drop="OnGridViewDrop"
                  DragLeave="OnGridViewDragLeave"
                  DoubleTapped="OnItemDoubleClick"
                  SelectionChanged="OnListSelectionChanged"
                  ContainerContentChanging="OnContainerContentChanging"
                  Background="Transparent"
                  Padding="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                  ScrollViewer.HorizontalScrollMode="Enabled"
                  ScrollViewer.VerticalScrollMode="Disabled">
            <GridView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Grid Padding="8,4,8,2">
                                <TextBlock Text="{Binding Key}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </GridView.GroupStyle>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Vertical"
                                   x:Name="ListWrapGrid"
                                   ItemWidth="250"
                                   ItemHeight="24"
                                   MaximumRowsOrColumns="0"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemContainerStyle>
                <StaticResource ResourceKey="ListViewItemStyle"/>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="vm:FileSystemViewModel">
                    <Grid Height="24" RightTapped="OnItemRightTapped"
                          ToolTipService.ToolTip="{x:Bind TooltipText}"
                          Opacity="{x:Bind ItemOpacity, Mode=OneWay}"
                          Padding="4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon (16px) -->
                        <Grid Grid.Column="0" Width="16" Height="16"
                              HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}" Stretch="UniformToFill"
                                   Visibility="{x:Bind vm:FileSystemViewModel.ShowIfTrue(HasThumbnail), Mode=OneWay}"/>
                            <FontIcon FontFamily="{StaticResource RemixIcons}"
                                      Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                                      Foreground="{x:Bind IconBrush, Mode=OneWay}"
                                      FontSize="16"
                                      Visibility="{x:Bind vm:FileSystemViewModel.ShowIfFalse(HasThumbnail), Mode=OneWay}"/>
                            <!-- Cloud sync badge -->
                            <Border Visibility="{x:Bind vm:FileSystemViewModel.ShowIfTrue(HasCloudBadge), Mode=OneWay}"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4,-4"
                                    Width="12" Height="12" CornerRadius="6"
                                    Background="{x:Bind CloudBadgeBrush, Mode=OneWay}">
                                <FontIcon Glyph="{x:Bind CloudStateGlyph, Mode=OneWay}" FontSize="8"
                                          Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Name (hidden during rename) -->
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind TruncatedDisplayName, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   FontSize="13"
                                   Padding="4,0"
                                   Visibility="{x:Bind vm:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>

                        <!-- Rename TextBox (visible during rename) -->
                        <TextBox Grid.Column="1"
                                 Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Padding="4,0" MinHeight="0" FontSize="13"
                                 Margin="0,-1,0,0"
                                 LostFocus="OnRenameTextBoxLostFocus"
                                 KeyDown="OnRenameTextBoxKeyDown"/>

                        <!-- Size (always visible) -->
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind Size, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                   TextAlignment="Right"
                                   MinWidth="40"
                                   Padding="4,0,4,0"/>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
        </Grid>
    </Grid>
</UserControl>
