<UserControl
    x:Class="Span.Views.IconModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Span.ViewModels"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Small Icon Template (16px) - Horizontal -->
        <DataTemplate x:Key="SmallIconTemplate" x:DataType="vm:FileSystemViewModel">
            <Grid Width="140" Height="22" Padding="6,0,4,0"
                  ToolTipService.ToolTip="{x:Bind TooltipText}"
                  Opacity="{x:Bind ItemOpacity, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center">
                    <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}" Stretch="UniformToFill"
                           Visibility="{x:Bind vm:FileSystemViewModel.ShowIfTrue(HasThumbnail), Mode=OneWay}"/>
                    <FontIcon FontFamily="{StaticResource RemixIcons}"
                              Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                              Foreground="{x:Bind IconBrush, Mode=OneWay}"
                              FontSize="14"
                              Visibility="{x:Bind vm:FileSystemViewModel.ShowIfFalse(HasThumbnail), Mode=OneWay}"/>
                    <!-- Cloud sync badge -->
                    <Border Visibility="{x:Bind vm:FileSystemViewModel.ShowIfTrue(HasCloudBadge), Mode=OneWay}"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-3,-3"
                            Width="10" Height="10" CornerRadius="5"
                            Background="{x:Bind CloudBadgeBrush, Mode=OneWay}">
                        <FontIcon Glyph="{x:Bind CloudStateGlyph, Mode=OneWay}" FontSize="7"
                                  Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <TextBlock Grid.Column="1"
                           Text="{x:Bind TruncatedDisplayName, Mode=OneWay}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           FontSize="13"
                           Visibility="{x:Bind vm:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                <TextBox Grid.Column="1"
                         Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center"
                         Padding="4,0" MinHeight="0" FontSize="13"
                         LostFocus="OnRenameTextBoxLostFocus"
                         KeyDown="OnRenameTextBoxKeyDown"/>
            </Grid>
        </DataTemplate>

        <!-- Medium Icon Template (48px) - Horizontal -->
        <DataTemplate x:Key="MediumIconTemplate" x:DataType="vm:FileSystemViewModel">
            <Grid Width="160" Height="48"
                  ToolTipService.ToolTip="{x:Bind TooltipText}"
                  Opacity="{x:Bind ItemOpacity, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Width="40" Height="40" Margin="0,0,10,0" VerticalAlignment="Center">
                    <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}" Stretch="UniformToFill"
                           Visibility="{x:Bind vm:FileSystemViewModel.ShowIfTrue(HasThumbnail), Mode=OneWay}"/>
                    <FontIcon FontFamily="{StaticResource RemixIcons}"
                              Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                              Foreground="{x:Bind IconBrush, Mode=OneWay}"
                              FontSize="40"
                              Visibility="{x:Bind vm:FileSystemViewModel.ShowIfFalse(HasThumbnail), Mode=OneWay}"/>
                    <!-- Cloud sync badge -->
                    <Border Visibility="{x:Bind vm:FileSystemViewModel.ShowIfTrue(HasCloudBadge), Mode=OneWay}"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4,-4"
                            Width="14" Height="14" CornerRadius="7"
                            Background="{x:Bind CloudBadgeBrush, Mode=OneWay}">
                        <FontIcon Glyph="{x:Bind CloudStateGlyph, Mode=OneWay}" FontSize="9"
                                  Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <TextBlock Grid.Column="1"
                           Text="{x:Bind TruncatedDisplayName, Mode=OneWay}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="Wrap"
                           MaxLines="2"
                           FontSize="13"
                           Visibility="{x:Bind vm:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                <TextBox Grid.Column="1"
                         Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center"
                         Padding="4,0" MinHeight="0" FontSize="13"
                         LostFocus="OnRenameTextBoxLostFocus"
                         KeyDown="OnRenameTextBoxKeyDown"/>
            </Grid>
        </DataTemplate>

        <!-- Large Icon Template (96px) - Vertical -->
        <DataTemplate x:Key="LargeIconTemplate" x:DataType="vm:FileSystemViewModel">
            <Grid Width="110" Height="120"
                  ToolTipService.ToolTip="{x:Bind TooltipText}"
                  Opacity="{x:Bind ItemOpacity, Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Width="80" Height="80" HorizontalAlignment="Center" Margin="0,4,0,4">
                    <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}" Stretch="Uniform"
                           Visibility="{x:Bind vm:FileSystemViewModel.ShowIfTrue(HasThumbnail), Mode=OneWay}"/>
                    <FontIcon FontFamily="{StaticResource RemixIcons}"
                              Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                              Foreground="{x:Bind IconBrush, Mode=OneWay}"
                              FontSize="80"
                              Visibility="{x:Bind vm:FileSystemViewModel.ShowIfFalse(HasThumbnail), Mode=OneWay}"/>
                    <!-- Cloud sync badge -->
                    <Border Visibility="{x:Bind vm:FileSystemViewModel.ShowIfTrue(HasCloudBadge), Mode=OneWay}"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,-2"
                            Width="16" Height="16" CornerRadius="8"
                            Background="{x:Bind CloudBadgeBrush, Mode=OneWay}">
                        <FontIcon Glyph="{x:Bind CloudStateGlyph, Mode=OneWay}" FontSize="10"
                                  Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="1"
                           Text="{x:Bind TruncatedDisplayName, Mode=OneWay}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="Wrap"
                           MaxLines="2"
                           FontSize="13"
                           Margin="4,0"
                           Visibility="{x:Bind vm:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                <TextBox Grid.Row="1"
                         Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         TextAlignment="Center"
                         VerticalContentAlignment="Center"
                         Padding="4,0" MinHeight="0" FontSize="13"
                         Margin="4,0"
                         LostFocus="OnRenameTextBoxLostFocus"
                         KeyDown="OnRenameTextBoxKeyDown"/>
            </Grid>
        </DataTemplate>

        <!-- Extra Large Icon Template (256px) - Vertical -->
        <DataTemplate x:Key="ExtraLargeIconTemplate" x:DataType="vm:FileSystemViewModel">
            <Grid Width="240" Height="260"
                  ToolTipService.ToolTip="{x:Bind TooltipText}"
                  Opacity="{x:Bind ItemOpacity, Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Width="200" Height="200" HorizontalAlignment="Center" Margin="0,6,0,6">
                    <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}" Stretch="Uniform"
                           Visibility="{x:Bind vm:FileSystemViewModel.ShowIfTrue(HasThumbnail), Mode=OneWay}"/>
                    <FontIcon FontFamily="{StaticResource RemixIcons}"
                              Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                              Foreground="{x:Bind IconBrush, Mode=OneWay}"
                              FontSize="180"
                              Visibility="{x:Bind vm:FileSystemViewModel.ShowIfFalse(HasThumbnail), Mode=OneWay}"/>
                    <!-- Cloud sync badge -->
                    <Border Visibility="{x:Bind vm:FileSystemViewModel.ShowIfTrue(HasCloudBadge), Mode=OneWay}"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,-2"
                            Width="20" Height="20" CornerRadius="10"
                            Background="{x:Bind CloudBadgeBrush, Mode=OneWay}">
                        <FontIcon Glyph="{x:Bind CloudStateGlyph, Mode=OneWay}" FontSize="12"
                                  Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="1"
                           Text="{x:Bind TruncatedDisplayName, Mode=OneWay}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="Wrap"
                           MaxLines="3"
                           FontSize="14"
                           Margin="8,0"
                           Visibility="{x:Bind vm:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                <TextBox Grid.Row="1"
                         Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         TextAlignment="Center"
                         VerticalContentAlignment="Center"
                         Padding="8,0" MinHeight="0" FontSize="14"
                         Margin="8,0"
                         LostFocus="OnRenameTextBoxLostFocus"
                         KeyDown="OnRenameTextBoxKeyDown"/>
            </Grid>
        </DataTemplate>

        <!-- Horizontal Template Reference (used by code-behind) -->
        <DataTemplate x:Key="HorizontalIconTemplate" x:DataType="vm:FileSystemViewModel">
            <ContentControl Content="{x:Bind}" ContentTemplate="{StaticResource MediumIconTemplate}"/>
        </DataTemplate>

        <!-- Vertical Template Reference (used by code-behind) -->
        <DataTemplate x:Key="VerticalIconTemplate" x:DataType="vm:FileSystemViewModel">
            <ContentControl Content="{x:Bind}" ContentTemplate="{StaticResource LargeIconTemplate}"/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Loaded="OnRootGridLoaded" Unloaded="OnRootGridUnloaded" Tapped="OnRootTapped" Background="Transparent">
        <GridView
            x:Name="IconGridView" AutomationProperties.AutomationId="Icon_GridView"
            ItemsSource="{Binding CurrentItems, Mode=OneWay}"
            SelectedItem="{Binding CurrentFolder.SelectedChild, Mode=TwoWay}"
            SelectionMode="Extended"
            CanDragItems="True"
            AllowDrop="True"
            Background="Transparent"
            DragItemsStarting="OnDragItemsStarting"
            DragItemsCompleted="OnDragItemsCompleted"
            DragOver="OnGridViewDragOver"
            Drop="OnGridViewDrop"
            DragLeave="OnGridViewDragLeave"
            DoubleTapped="OnItemDoubleClick"
            KeyDown="OnIconKeyDown"
            SelectionChanged="OnIconSelectionChanged"
            ContainerContentChanging="OnContainerContentChanging"
            RightTapped="OnItemRightTapped"
            Padding="16">

            <GridView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Grid Padding="8,6,8,2">
                                <TextBlock Text="{Binding Key}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </GridView.GroupStyle>

            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"
                                   HorizontalAlignment="Left"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <!-- Default to Medium Icon Template -->
            <GridView.ItemTemplate>
                <StaticResource ResourceKey="MediumIconTemplate"/>
            </GridView.ItemTemplate>

            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem" BasedOn="{StaticResource ListViewItemStyle}">
                    <Setter Property="Margin" Value="4"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </GridView.ItemContainerStyle>
        </GridView>
    </Grid>
</UserControl>
