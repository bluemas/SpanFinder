                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Tabler Icons" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                                <TextBlock Text="Tabler — MIT License" FontSize="11" Foreground="{ThemeResource SpanTextTertiaryBrush}" />
                                            </StackPanel>
                                            <TextBlock x:Name="AvailableText2" Grid.Column="1" Text="선택 가능" FontSize="11" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Full license link -->
                            <HyperlinkButton Style="{StaticResource LinkButtonStyle}" Margin="0,12,0,0"
                                             NavigateUri="https://github.com/LumiBearStudio/SpanFinder/blob/main/OpenSourceLicenses.md">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                                    <TextBlock x:Name="FullLicenseLink" Text="View full license text on GitHub" />
                                </StackPanel>
                            </HyperlinkButton>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
</UserControl>
