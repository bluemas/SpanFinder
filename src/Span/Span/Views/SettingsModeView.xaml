<UserControl
    x:Class="Span.Views.SettingsModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:Span.Helpers"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Settings Card Style -->
        <Style x:Key="SettingsCardBorder" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource SpanBgLayer1Brush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <!-- Section Title Style -->
        <Style x:Key="SettingsSectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{ThemeResource SpanTextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <!-- Card Label Style -->
        <Style x:Key="SettingsCardLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource SpanTextPrimaryBrush}" />
        </Style>

        <!-- Card Description Style -->
        <Style x:Key="SettingsCardDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{ThemeResource SpanTextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- Toggle Row Label Style -->
        <Style x:Key="ToggleRowLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{ThemeResource SpanTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Segmented Button Style -->
        <Style x:Key="SegmentedButton" TargetType="RadioButton">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{ThemeResource SpanTextSecondaryBrush}" />
        </Style>

        <!-- Link Button Style -->
        <Style x:Key="LinkButtonStyle" TargetType="HyperlinkButton">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!-- Card Icon Style -->
        <Style x:Key="CardIconStyle" TargetType="FontIcon">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{ThemeResource SpanAccentBrush}" />
        </Style>

        <!-- Card Icon Container -->
        <Style x:Key="CardIconContainer" TargetType="Border">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{ThemeResource SpanBgLayer2Brush}" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- (ProBadge removed — no Pro tier) -->

        <!-- Shortcut Code Style -->
        <Style x:Key="ShortcutCode" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource SpanBgLayer2Brush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <!-- Card-style RadioButton: padded root grid so radio circle doesn't hug the border -->
        <Style x:Key="CardRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Padding" Value="8,6,6,4" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="{ThemeResource SpanTextTertiaryBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid x:Name="RootGrid"
                              Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              CornerRadius="{TemplateBinding CornerRadius}"
                              Padding="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" VerticalAlignment="Top" Height="32">
                                <Ellipse x:Name="OuterEllipse" Width="20" Height="20" UseLayoutRounding="False"
                                         Stroke="{ThemeResource RadioButtonOuterEllipseStroke}"
                                         StrokeThickness="{ThemeResource RadioButtonBorderThemeThickness}"
                                         Fill="{ThemeResource RadioButtonOuterEllipseFill}" />
                                <Ellipse x:Name="CheckOuterEllipse" Width="20" Height="20" UseLayoutRounding="False"
                                         Stroke="{ThemeResource RadioButtonOuterEllipseCheckedStroke}"
                                         Fill="{ThemeResource RadioButtonOuterEllipseCheckedFill}" Opacity="0" />
                                <Ellipse x:Name="CheckGlyph" Width="8" Height="8" UseLayoutRounding="False"
                                         Fill="{ThemeResource RadioButtonCheckGlyphFill}" Opacity="0" />
                            </Grid>
                            <ContentPresenter x:Name="ContentPresenter" Grid.Column="1"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              ContentTransitions="{TemplateBinding ContentTransitions}"
                                              Margin="6,0,0,0"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              TextWrapping="Wrap" AutomationProperties.AccessibilityView="Raw" />
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource RadioButtonBackgroundPointerOver}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource RadioButtonBorderBrushPointerOver}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OuterEllipse" Storyboard.TargetProperty="Stroke">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource RadioButtonOuterEllipseStrokePointerOver}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OuterEllipse" Storyboard.TargetProperty="Fill">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource RadioButtonOuterEllipseFillPointerOver}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CheckOuterEllipse" Storyboard.TargetProperty="Stroke">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource RadioButtonOuterEllipseCheckedStrokePointerOver}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CheckOuterEllipse" Storyboard.TargetProperty="Fill">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource RadioButtonOuterEllipseCheckedFillPointerOver}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CheckGlyph" Storyboard.TargetProperty="Fill">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource RadioButtonCheckGlyphFillPointerOver}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource RadioButtonBackgroundPressed}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource RadioButtonBorderBrushPressed}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OuterEllipse" Storyboard.TargetProperty="Stroke">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource RadioButtonOuterEllipseStrokePressed}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OuterEllipse" Storyboard.TargetProperty="Fill">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource RadioButtonOuterEllipseFillPressed}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CheckOuterEllipse" Storyboard.TargetProperty="Stroke">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource RadioButtonOuterEllipseCheckedStrokePressed}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CheckOuterEllipse" Storyboard.TargetProperty="Fill">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource RadioButtonOuterEllipseCheckedFillPressed}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CheckGlyph" Storyboard.TargetProperty="Fill">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource RadioButtonCheckGlyphFillPressed}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled" />
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CheckGlyph" Storyboard.TargetProperty="Opacity" To="1" Duration="0" />
                                            <DoubleAnimation Storyboard.TargetName="OuterEllipse" Storyboard.TargetProperty="Opacity" To="0" Duration="0" />
                                            <DoubleAnimation Storyboard.TargetName="CheckOuterEllipse" Storyboard.TargetProperty="Opacity" To="1" Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked" />
                                    <VisualState x:Name="Indeterminate" />
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header (주소창 영역과 동일 사이즈) -->
        <Grid Grid.Row="0" Height="{StaticResource CommandBarHeight}"
              Background="{ThemeResource SpanBgLayer1Brush}"
              BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,0,1"
              Padding="12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <FontIcon Grid.Column="0" Glyph="&#xE713;" FontSize="14"
                      Foreground="{ThemeResource SpanAccentBrush}"
                      VerticalAlignment="Center"/>
            <TextBlock x:Name="SettingsTitle" Grid.Column="1" Text="설정" FontSize="13" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>
        </Grid>

        <!-- 사이드바 + 콘텐츠 (탐색기 사이드바와 동일 구조) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 사이드바: 탐색기와 완전 동일 -->
            <Border Grid.Column="0" Background="{ThemeResource SpanBgLayer1Brush}"
                    BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Padding="0,4">
                        <Grid x:Name="NavGeneral" Height="28" Padding="12,0" Tag="General"
                              Background="{ThemeResource SpanBgSelectedBrush}"
                              Tapped="OnNavItemTapped"
                              PointerEntered="OnNavItemPointerEntered" PointerExited="OnNavItemPointerExited"
                              helpers:CursorHelper.IsHandCursor="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE713;" FontSize="16"
                                      Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" Text="일반" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid x:Name="NavAppearance" Height="28" Padding="12,0" Tag="Appearance"
                              Background="Transparent"
                              Tapped="OnNavItemTapped"
                              PointerEntered="OnNavItemPointerEntered" PointerExited="OnNavItemPointerExited"
                              helpers:CursorHelper.IsHandCursor="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE790;" FontSize="16"
                                      Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" Text="모양" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid x:Name="NavBrowsing" Height="28" Padding="12,0" Tag="Browsing"
                              Background="Transparent"
                              Tapped="OnNavItemTapped"
                              PointerEntered="OnNavItemPointerEntered" PointerExited="OnNavItemPointerExited"
                              helpers:CursorHelper.IsHandCursor="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE8B0;" FontSize="16"
                                      Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" Text="탐색" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid x:Name="NavTools" Height="28" Padding="12,0" Tag="Tools"
                              Background="Transparent"
                              Tapped="OnNavItemTapped"
                              PointerEntered="OnNavItemPointerEntered" PointerExited="OnNavItemPointerExited"
                              helpers:CursorHelper.IsHandCursor="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE756;" FontSize="16"
                                      Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" Text="도구" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid x:Name="NavAdvanced" Height="28" Padding="12,0" Tag="Advanced"
                              Background="Transparent"
                              Tapped="OnNavItemTapped"
                              PointerEntered="OnNavItemPointerEntered" PointerExited="OnNavItemPointerExited"
                              helpers:CursorHelper.IsHandCursor="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE90F;" FontSize="16"
                                      Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" Text="고급" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="12,12"/>
                        <Grid x:Name="NavAbout" Height="28" Padding="12,0" Tag="About"
                              Background="Transparent"
                              Tapped="OnNavItemTapped"
                              PointerEntered="OnNavItemPointerEntered" PointerExited="OnNavItemPointerExited"
                              helpers:CursorHelper.IsHandCursor="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE946;" FontSize="16"
                                      Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" Text="정보" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Grid x:Name="NavOpenSource" Height="28" Padding="12,0" Tag="OpenSource"
                              Background="Transparent"
                              Tapped="OnNavItemTapped"
                              PointerEntered="OnNavItemPointerEntered" PointerExited="OnNavItemPointerExited"
                              helpers:CursorHelper.IsHandCursor="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE943;" FontSize="16"
                                      Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" Text="오픈소스" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 콘텐츠 영역 -->
            <Grid Grid.Column="1">
                    <!-- ===== General Section ===== -->
                    <ScrollViewer x:Name="GeneralSection" AutomationProperties.AutomationId="SettingsScrollViewer" Visibility="Visible">
                        <StackPanel Padding="20" Spacing="0">
                            <TextBlock x:Name="GeneralTitle" Text="일반" Style="{StaticResource SettingsSectionTitle}" />

                            <!-- Language -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <StackPanel Spacing="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                            <FontIcon Glyph="&#xE774;" Style="{StaticResource CardIconStyle}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock x:Name="LangLabel" Text="언어 (Language)" Style="{StaticResource SettingsCardLabel}" />
                                            <TextBlock x:Name="LangDesc" Text="앱 인터페이스 표시 언어" Style="{StaticResource SettingsCardDesc}" />
                                        </StackPanel>
                                        <ComboBox x:Name="LanguageCombo" Grid.Column="2" SelectedIndex="0" MinWidth="180"
                                                 VerticalAlignment="Center" SelectionChanged="LanguageCombo_SelectionChanged">
                                            <ComboBoxItem x:Name="LangSystem" Content="System Default (권장)" />
                                            <ComboBoxItem Content="English" />
                                            <ComboBoxItem Content="한국어" />
                                            <ComboBoxItem Content="日本語" />
                                            <ComboBoxItem Content="简体中文" />
                                            <ComboBoxItem Content="繁體中文" />
                                            <ComboBoxItem Content="Deutsch" />
                                            <ComboBoxItem Content="Español" />
                                            <ComboBoxItem Content="Français" />
                                            <ComboBoxItem Content="Português (BR)" />
                                        </ComboBox>
                                    </Grid>
                                    <!-- Restart Notice -->
                                    <StackPanel x:Name="LangRestartNotice" Orientation="Horizontal" Spacing="8"
                                                Margin="48,8,0,0" Padding="10,8"
                                                Background="#1AFF8C00" CornerRadius="6"
                                                Visibility="Collapsed">
                                        <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="#FF8C00" />
                                        <TextBlock x:Name="LangRestartText" Text="앱을 재시작해야 완벽하게 적용됩니다." FontSize="12"
                                                   Foreground="#FF8C00" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Split View Settings (Left/Right side-by-side) -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Style="{StaticResource CardIconContainer}">
                                            <FontIcon Glyph="&#xE7A5;" Style="{StaticResource CardIconStyle}" />
                                        </Border>
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <TextBlock x:Name="StartupLabel" Text="분할뷰 설정" Style="{StaticResource SettingsCardLabel}" />
                                            <TextBlock x:Name="StartupDesc" Text="분할뷰의 왼쪽/오른쪽 탐색기 시작 동작" Style="{StaticResource SettingsCardDesc}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Two-column layout: Left | Right -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Left Explorer -->
                                        <Border Grid.Column="0" Background="{ThemeResource SpanBgLayer2Brush}" CornerRadius="6" Padding="12">
                                            <StackPanel Spacing="8">
                                                <TextBlock x:Name="Tab1Label" Text="왼쪽 탐색기" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                                <RadioButton x:Name="Tab1StartupHome" GroupName="Tab1Startup" IsChecked="True" MinHeight="28" Padding="8,4,0,0">
                                                    <TextBlock x:Name="Tab1HomeText" Text="내 PC (홈) 열기" FontSize="13" />
                                                </RadioButton>
                                                <RadioButton x:Name="Tab1StartupRestore" GroupName="Tab1Startup" MinHeight="28" Padding="8,4,0,0">
                                                    <TextBlock x:Name="Tab1RestoreText" Text="마지막 세션 복원" FontSize="13" />
                                                </RadioButton>
                                                <RadioButton x:Name="Tab1StartupCustom" GroupName="Tab1Startup" MinHeight="28" Padding="8,4,0,0"
                                                             HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock x:Name="Tab1CustomText" Text="시작 경로:" FontSize="13"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                                                        <TextBox x:Name="Tab1CustomPathBox" Grid.Column="1" PlaceholderText="C:\Users\..." FontSize="12"
                                                                 VerticalAlignment="Center" Visibility="{x:Bind Tab1StartupCustom.IsChecked, Mode=OneWay}" />
                                                        <Button x:Name="Tab1BrowseBtn" Grid.Column="2" Content="..." Margin="4,0,0,0"
                                                                MinWidth="36" VerticalAlignment="Center" Visibility="{x:Bind Tab1StartupCustom.IsChecked, Mode=OneWay}" />
                                                    </Grid>
                                                </RadioButton>

                                                <!-- Left View Mode -->
                                                <Border BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,1,0,0" Padding="0,8,0,0" Margin="0,4,0,0">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock x:Name="Tab1ViewLabel" Text="뷰 모드:" FontSize="13" VerticalAlignment="Center"
                                                                   Foreground="{ThemeResource SpanTextSecondaryBrush}" />
                                                        <ComboBox x:Name="Tab1ViewModeCombo" MinWidth="120" SelectedIndex="0">
                                                            <ComboBoxItem x:Name="Tab1ViewMiller" Content="밀러 컬럼" />
                                                            <ComboBoxItem x:Name="Tab1ViewDetails" Content="상세 정보" />
                                                            <ComboBoxItem x:Name="Tab1ViewList" Content="리스트" />
                                                            <ComboBoxItem x:Name="Tab1ViewIcon" Content="아이콘" />
                                                        </ComboBox>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <!-- Right Explorer -->
                                        <Border Grid.Column="2" Background="{ThemeResource SpanBgLayer2Brush}" CornerRadius="6" Padding="12">
                                            <StackPanel Spacing="8">
                                                <TextBlock x:Name="Tab2Label" Text="오른쪽 탐색기" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                                <RadioButton x:Name="Tab2StartupHome" GroupName="Tab2Startup" IsChecked="True" MinHeight="28" Padding="8,4,0,0">
                                                    <TextBlock x:Name="Tab2HomeText" Text="내 PC (홈) 열기" FontSize="13" />
                                                </RadioButton>
                                                <RadioButton x:Name="Tab2StartupRestore" GroupName="Tab2Startup" MinHeight="28" Padding="8,4,0,0">
                                                    <TextBlock x:Name="Tab2RestoreText" Text="마지막 세션 복원" FontSize="13" />
                                                </RadioButton>
                                                <RadioButton x:Name="Tab2StartupCustom" GroupName="Tab2Startup" MinHeight="28" Padding="8,4,0,0"
                                                             HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock x:Name="Tab2CustomText" Text="시작 경로:" FontSize="13"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                                                        <TextBox x:Name="Tab2CustomPathBox" Grid.Column="1" PlaceholderText="C:\Users\..." FontSize="12"
                                                                 VerticalAlignment="Center" Visibility="{x:Bind Tab2StartupCustom.IsChecked, Mode=OneWay}" />
                                                        <Button x:Name="Tab2BrowseBtn" Grid.Column="2" Content="..." Margin="4,0,0,0"
                                                                MinWidth="36" VerticalAlignment="Center" Visibility="{x:Bind Tab2StartupCustom.IsChecked, Mode=OneWay}" />
                                                    </Grid>
