                                                <Border CornerRadius="4" Padding="8,8" Height="52" Background="{ThemeResource SpanBgLayer2Brush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1">
                                                    <StackPanel Spacing="4" VerticalAlignment="Center">
                                                        <Border Height="3" CornerRadius="1" Background="{ThemeResource SpanAccentBrush}" Opacity="0.7" HorizontalAlignment="Stretch" />
                                                        <Border Height="3" CornerRadius="1" Background="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.4" HorizontalAlignment="Stretch" />
                                                        <Border Height="3" CornerRadius="1" Background="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.4" HorizontalAlignment="Stretch" />
                                                        <Border Height="3" CornerRadius="1" Background="{ThemeResource SpanAccentBrush}" Opacity="0.7" HorizontalAlignment="Stretch" />
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="M" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>

                                        <!-- Density 3: L -->
                                        <RadioButton x:Name="Density3" GroupName="Density" Width="156"
                                                     Style="{StaticResource CardRadioButtonStyle}">
                                            <StackPanel Spacing="0">
                                                <Border CornerRadius="4" Padding="8,8" Height="52" Background="{ThemeResource SpanBgLayer2Brush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1">
                                                    <StackPanel Spacing="6" VerticalAlignment="Center">
                                                        <Border Height="3" CornerRadius="1" Background="{ThemeResource SpanAccentBrush}" Opacity="0.7" HorizontalAlignment="Stretch" />
                                                        <Border Height="3" CornerRadius="1" Background="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.4" HorizontalAlignment="Stretch" />
                                                        <Border Height="3" CornerRadius="1" Background="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.4" HorizontalAlignment="Stretch" />
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="L" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>

                                        <!-- Density 4: XL -->
                                        <RadioButton x:Name="Density4" GroupName="Density" Width="156"
                                                     Style="{StaticResource CardRadioButtonStyle}">
                                            <StackPanel Spacing="0">
                                                <Border CornerRadius="4" Padding="8,8" Height="52" Background="{ThemeResource SpanBgLayer2Brush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1">
                                                    <StackPanel Spacing="8" VerticalAlignment="Center">
                                                        <Border Height="3" CornerRadius="1" Background="{ThemeResource SpanAccentBrush}" Opacity="0.7" HorizontalAlignment="Stretch" />
                                                        <Border Height="3" CornerRadius="1" Background="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.4" HorizontalAlignment="Stretch" />
                                                        <Border Height="3" CornerRadius="1" Background="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.4" HorizontalAlignment="Stretch" />
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="XL" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>

                                        <!-- Density 5: XXL -->
                                        <RadioButton x:Name="Density5" GroupName="Density" Width="156"
                                                     Style="{StaticResource CardRadioButtonStyle}">
                                            <StackPanel Spacing="0">
                                                <Border CornerRadius="4" Padding="8,8" Height="52" Background="{ThemeResource SpanBgLayer2Brush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1">
                                                    <StackPanel Spacing="10" VerticalAlignment="Center">
                                                        <Border Height="3" CornerRadius="1" Background="{ThemeResource SpanAccentBrush}" Opacity="0.7" HorizontalAlignment="Stretch" />
                                                        <Border Height="3" CornerRadius="1" Background="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.4" HorizontalAlignment="Stretch" />
                                                        <Border Height="3" CornerRadius="1" Background="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.4" HorizontalAlignment="Stretch" />
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="XXL" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>
                                    </helpers:WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- ═══ Icon & Font Size ═══ -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <StackPanel Spacing="14">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Style="{StaticResource CardIconContainer}">
                                            <FontIcon Glyph="&#xE8E8;" Style="{StaticResource CardIconStyle}" />
                                        </Border>
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <TextBlock x:Name="IconFontScaleLabel" Text="아이콘 및 글꼴 크기" Style="{StaticResource SettingsCardLabel}" />
                                            <TextBlock x:Name="IconFontScaleDesc" Text="사이드바, 탐색기 항목의 아이콘과 텍스트 크기" Style="{StaticResource SettingsCardDesc}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <helpers:WrapPanel Margin="48,0,0,0" HorizontalSpacing="8" VerticalSpacing="8">
                                        <helpers:WrapPanel.Resources>
                                            <SolidColorBrush x:Key="RadioButtonBackgroundPointerOver" Color="{ThemeResource SpanBgLayer3Color}" />
                                            <SolidColorBrush x:Key="RadioButtonBorderBrushPointerOver" Color="{ThemeResource SpanAccentHoverColor}" />
                                            <SolidColorBrush x:Key="RadioButtonBackgroundPressed" Color="{ThemeResource SpanBgLayer3Color}" />
                                            <SolidColorBrush x:Key="RadioButtonBorderBrushPressed" Color="{ThemeResource SpanAccentColor}" />
                                        </helpers:WrapPanel.Resources>

                                        <!-- Scale 0: 기본 (13px/16px) -->
                                        <RadioButton x:Name="Scale0" GroupName="IconFontScale" Width="156"
                                                     Style="{StaticResource CardRadioButtonStyle}" IsChecked="True">
                                            <StackPanel Spacing="0">
                                                <Border CornerRadius="4" Padding="10,8" Height="52" Background="{ThemeResource SpanBgLayer2Brush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                        <Border Width="13" Height="13" CornerRadius="3" Background="{ThemeResource SpanAccentBrush}" Opacity="0.7" />
                                                        <StackPanel Spacing="2">
                                                            <Border Height="3" Width="40" CornerRadius="1" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                            <Border Height="2" Width="28" CornerRadius="1" Background="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.3" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="XS" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>

                                        <!-- Scale 1: +1px -->
                                        <RadioButton x:Name="Scale1" GroupName="IconFontScale" Width="156"
                                                     Style="{StaticResource CardRadioButtonStyle}">
                                            <StackPanel Spacing="0">
                                                <Border CornerRadius="4" Padding="10,8" Height="52" Background="{ThemeResource SpanBgLayer2Brush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                        <Border Width="15" Height="15" CornerRadius="3" Background="{ThemeResource SpanAccentBrush}" Opacity="0.7" />
                                                        <StackPanel Spacing="2">
                                                            <Border Height="3" Width="42" CornerRadius="1" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                            <Border Height="2" Width="30" CornerRadius="1" Background="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.3" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="S" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>

                                        <!-- Scale 2: +2px -->
                                        <RadioButton x:Name="Scale2" GroupName="IconFontScale" Width="156"
                                                     Style="{StaticResource CardRadioButtonStyle}">
                                            <StackPanel Spacing="0">
                                                <Border CornerRadius="4" Padding="10,8" Height="52" Background="{ThemeResource SpanBgLayer2Brush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                        <Border Width="17" Height="17" CornerRadius="3" Background="{ThemeResource SpanAccentBrush}" Opacity="0.7" />
                                                        <StackPanel Spacing="2">
                                                            <Border Height="4" Width="44" CornerRadius="1" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                            <Border Height="3" Width="32" CornerRadius="1" Background="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.3" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="M" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>

                                        <!-- Scale 3: +3px -->
                                        <RadioButton x:Name="Scale3" GroupName="IconFontScale" Width="156"
                                                     Style="{StaticResource CardRadioButtonStyle}">
                                            <StackPanel Spacing="0">
                                                <Border CornerRadius="4" Padding="10,8" Height="52" Background="{ThemeResource SpanBgLayer2Brush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                        <Border Width="19" Height="19" CornerRadius="4" Background="{ThemeResource SpanAccentBrush}" Opacity="0.7" />
                                                        <StackPanel Spacing="2">
                                                            <Border Height="4" Width="46" CornerRadius="1" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                            <Border Height="3" Width="34" CornerRadius="1" Background="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.3" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="L" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>

                                        <!-- Scale 4: +4px -->
                                        <RadioButton x:Name="Scale4" GroupName="IconFontScale" Width="156"
                                                     Style="{StaticResource CardRadioButtonStyle}">
                                            <StackPanel Spacing="0">
                                                <Border CornerRadius="4" Padding="10,8" Height="52" Background="{ThemeResource SpanBgLayer2Brush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                        <Border Width="21" Height="21" CornerRadius="4" Background="{ThemeResource SpanAccentBrush}" Opacity="0.7" />
                                                        <StackPanel Spacing="3">
                                                            <Border Height="4" Width="48" CornerRadius="1" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                            <Border Height="3" Width="36" CornerRadius="1" Background="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.3" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="XL" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>

                                        <!-- Scale 5: +5px -->
                                        <RadioButton x:Name="Scale5" GroupName="IconFontScale" Width="156"
                                                     Style="{StaticResource CardRadioButtonStyle}">
                                            <StackPanel Spacing="0">
                                                <Border CornerRadius="4" Padding="10,8" Height="52" Background="{ThemeResource SpanBgLayer2Brush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                        <Border Width="23" Height="23" CornerRadius="5" Background="{ThemeResource SpanAccentBrush}" Opacity="0.7" />
                                                        <StackPanel Spacing="3">
                                                            <Border Height="5" Width="50" CornerRadius="1" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                            <Border Height="3" Width="38" CornerRadius="1" Background="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.3" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="XXL" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>
                                    </helpers:WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- ═══ List View Item Width ═══ -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <StackPanel Spacing="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Style="{StaticResource CardIconContainer}">
                                                <FontIcon Glyph="&#xE8C4;" Style="{StaticResource CardIconStyle}" />
                                            </Border>
                                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                                <TextBlock x:Name="ListWidthLabel" Text="리스트 뷰 아이템 너비" Style="{StaticResource SettingsCardLabel}" />
                                                <TextBlock x:Name="ListWidthDesc" Text="리스트 뷰 모드에서 각 항목의 너비" Style="{StaticResource SettingsCardDesc}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock x:Name="ListWidthValue" Text="250px" FontSize="12"
                                                       Foreground="{ThemeResource SpanTextSecondaryBrush}" VerticalAlignment="Center" />
                                            <Slider x:Name="ListWidthSlider" Minimum="150" Maximum="500" Value="250"
                                                    Width="150" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Icon Pack -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <StackPanel Spacing="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                            <FontIcon Glyph="&#xE8B9;" Style="{StaticResource CardIconStyle}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock x:Name="IconPackLabel" Text="아이콘 팩" Style="{StaticResource SettingsCardLabel}" />
                                            <TextBlock x:Name="IconPackDesc" Text="파일/폴더 아이콘 스타일" Style="{StaticResource SettingsCardDesc}" />
                                        </StackPanel>
                                        <ComboBox x:Name="IconPackCombo" Grid.Column="2" SelectedIndex="0"
                                                  MinWidth="140" VerticalAlignment="Center">
                                            <ComboBoxItem Content="Remix Icon" />
                                            <ComboBoxItem Content="Phosphor" />
                                            <ComboBoxItem Content="Tabler" />
                                        </ComboBox>
                                    </Grid>
                                    <StackPanel x:Name="IconPackRestartNotice" Orientation="Horizontal" Spacing="8"
                                                Margin="48,8,0,0" Padding="10,8"
                                                Background="#1AFF8C00" CornerRadius="6" Visibility="Collapsed">
                                        <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="#FF8C00" />
                                        <TextBlock x:Name="IconPackRestartText" Text="아이콘 팩 변경은 앱 재시작 후 적용됩니다" FontSize="12"
                                                   Foreground="#FF8C00" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Font -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE8D2;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="FontLabel" Text="폰트" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="FontDesc" Text="파일 이름 표시에 사용할 폰트" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ComboBox x:Name="FontCombo" Grid.Column="2" SelectedIndex="0" MinWidth="160" VerticalAlignment="Center">
                                        <!-- Sans-serif -->
                                        <ComboBoxItem Content="Segoe UI Variable" />
                                        <ComboBoxItem Content="Arial" />
                                        <ComboBoxItem Content="Verdana" />
                                        <ComboBoxItem Content="Calibri" />
                                        <!-- Monospace -->
                                        <ComboBoxItem Content="Cascadia Code" />
                                        <ComboBoxItem Content="Consolas" />
                                        <ComboBoxItem Content="Courier New" />
                                        <!-- CJK-optimized -->
                                        <ComboBoxItem Content="Malgun Gothic" />
                                        <ComboBoxItem Content="Microsoft YaHei UI" />
                                        <ComboBoxItem Content="Yu Gothic UI" />
                                    </ComboBox>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ===== Browsing Section ===== -->
                    <ScrollViewer x:Name="BrowsingSection" Visibility="Collapsed">
                        <StackPanel Padding="20" Spacing="0">
                            <TextBlock x:Name="BrowsingTitle" Text="탐색" Style="{StaticResource SettingsSectionTitle}" />

                            <!-- View Options -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Style="{StaticResource CardIconContainer}">
                                            <FontIcon Glyph="&#xE7B3;" Style="{StaticResource CardIconStyle}" />
                                        </Border>
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <TextBlock x:Name="ViewOptionsLabel" Text="보기 옵션" Style="{StaticResource SettingsCardLabel}" />
                                            <TextBlock x:Name="ViewOptionsDesc" Text="파일 표시 관련 설정" Style="{StaticResource SettingsCardDesc}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Grid Margin="48,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock x:Name="ShowHiddenLabel" Text="숨김 항목 표시" Style="{StaticResource ToggleRowLabel}" />
                                            <TextBlock Text="(Ctrl+H)" FontSize="11" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <ToggleSwitch x:Name="ShowHiddenToggle" Grid.Column="1" IsOn="False" OnContent="" OffContent="" />
                                    </Grid>
                                    <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="48,0,0,0" />
                                    <Grid Margin="48,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="ShowExtLabel" Grid.Column="0" Text="파일 확장자 표시" Style="{StaticResource ToggleRowLabel}" />
                                        <ToggleSwitch x:Name="ShowExtensionsToggle" Grid.Column="1" IsOn="True" OnContent="" OffContent="" />
                                    </Grid>
                                    <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="48,0,0,0" />
                                    <Grid Margin="48,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="CheckboxLabel" Grid.Column="0" Text="체크박스 사용하여 항목 선택" Style="{StaticResource ToggleRowLabel}" />
                                        <ToggleSwitch x:Name="CheckboxToggle" Grid.Column="1" IsOn="False" OnContent="" OffContent="" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Miller Column Behavior -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE80A;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="MillerLabel" Text="밀러 컬럼 동작" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="MillerDesc" Text="폴더 열기 방식" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ComboBox x:Name="MillerClickCombo" Grid.Column="2" SelectedIndex="0" MinWidth="140" VerticalAlignment="Center">
                                        <ComboBoxItem x:Name="SingleClickItem" Content="한 번 클릭" />
                                        <ComboBoxItem x:Name="DoubleClickItem" Content="더블 클릭" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- Image Thumbnails -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE8B9;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="ThumbnailLabel" Text="이미지 미리보기 (썸네일)" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="ThumbnailDesc" Text="성능을 위해 네트워크 드라이브에서는 썸네일을 끕니다" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="ThumbnailToggle" Grid.Column="2" VerticalAlignment="Center" IsOn="True" OnContent="" OffContent="" />
                                </Grid>
                            </Border>

                            <!-- Quick Look -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE773;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="QuickLookLabel" Text="Quick Look (빠른 미리보기)" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="QuickLookDesc" Text="Space 키로 파일을 빠르게 미리봅니다" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="QuickLookToggle" Grid.Column="2" VerticalAlignment="Center" IsOn="True" OnContent="" OffContent="" />
                                </Grid>
                            </Border>

                            <!-- Miller Inline Preview -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE8A1;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="MillerInlinePreviewLabel" Text="밀러 컬럼 인라인 미리보기" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="MillerInlinePreviewDesc" Text="밀러 컬럼 뷰에서 파일 선택 시 오른쪽에 미리보기를 표시합니다" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="MillerInlinePreviewToggle" Grid.Column="2" VerticalAlignment="Center" IsOn="True" OnContent="" OffContent="" />
                                </Grid>
                            </Border>

                            <!-- Preview: Show Folder Info (숨김 — 향후 시나리오 안정화 후 공개) -->
                            <Border Style="{StaticResource SettingsCardBorder}" Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE8B7;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="PreviewFolderInfoLabel" Text="미리보기에 폴더 정보 표시" Style="{StaticResource SettingsCardLabel}" />
