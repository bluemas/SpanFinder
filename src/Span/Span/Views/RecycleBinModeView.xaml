<UserControl
    x:Class="Span.Views.RecycleBinModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Span.Models"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:helpers="using:Span.Helpers"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="{ThemeResource SpanTextSecondaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter
                            Content="{TemplateBinding Content}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Padding="{TemplateBinding Padding}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Tapped="OnRootTapped" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Column Headers (DetailsModeView pattern) -->
        <Grid Grid.Row="0" Height="24"
              x:Name="HeaderGrid"
              Background="{ThemeResource SpanBgLayer2Brush}"
              BorderBrush="{ThemeResource SpanBorderSubtleBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="*" MinWidth="100"/>
                <ColumnDefinition x:Name="Splitter1ColDef" Width="Auto"/>
                <ColumnDefinition x:Name="OrigLocationColumnDef" Width="200" MinWidth="80"/>
                <ColumnDefinition x:Name="Splitter2ColDef" Width="Auto"/>
                <ColumnDefinition x:Name="DateDeletedColumnDef" Width="200" MinWidth="80"/>
                <ColumnDefinition x:Name="Splitter3ColDef" Width="Auto"/>
                <ColumnDefinition x:Name="SizeColumnDef" Width="100" MinWidth="50"/>
                <ColumnDefinition x:Name="Splitter4ColDef" Width="Auto"/>
                <ColumnDefinition x:Name="TypeColumnDef" Width="150" MinWidth="50"/>
            </Grid.ColumnDefinitions>

            <!-- Name Header -->
            <Button x:Name="NameHeaderButton" Grid.Column="0" Grid.ColumnSpan="2"
                    Content="Name"
                    Click="OnHeaderClick"
                    Tag="Name"
                    Padding="11,0,6,0"
                    helpers:CursorHelper.IsHandCursor="True"
                    Style="{StaticResource HeaderButtonStyle}"/>

            <!-- Splitter 1: Name | Original Location -->
            <controls:GridSplitter x:Name="Splitter1" Grid.Column="2"
                                   Width="2" Padding="0" Margin="0"
                                   ResizeDirection="Columns"
                                   HorizontalAlignment="Center"
                                   Background="Transparent" Opacity="0.3"/>

            <!-- Original Location Header -->
            <Grid Grid.Column="3">
                <Button x:Name="OrigLocationHeaderButton"
                        Content="Original Location"
                        Click="OnHeaderClick"
                        Tag="OriginalLocation"
                        helpers:CursorHelper.IsHandCursor="True"
                        Style="{StaticResource HeaderButtonStyle}"/>
            </Grid>

            <!-- Splitter 2: Original Location | Date Deleted -->
            <controls:GridSplitter x:Name="Splitter2" Grid.Column="4"
                                   Width="2" Padding="0" Margin="0"
                                   ResizeDirection="Columns"
                                   HorizontalAlignment="Center"
                                   Background="Transparent" Opacity="0.3"/>

            <!-- Date Deleted Header -->
            <Grid Grid.Column="5">
                <Button x:Name="DateDeletedHeaderButton"
                        Content="Date Deleted"
                        Click="OnHeaderClick"
                        Tag="DateDeleted"
                        helpers:CursorHelper.IsHandCursor="True"
                        Style="{StaticResource HeaderButtonStyle}"/>
            </Grid>

            <!-- Splitter 3: Date Deleted | Size -->
            <controls:GridSplitter x:Name="Splitter3" Grid.Column="6"
                                   Width="2" Padding="0" Margin="0"
                                   ResizeDirection="Columns"
                                   HorizontalAlignment="Center"
                                   Background="Transparent" Opacity="0.3"/>

            <!-- Size Header -->
            <Grid Grid.Column="7">
                <Button x:Name="SizeHeaderButton"
                        Content="Size"
                        Click="OnHeaderClick"
                        Tag="Size"
                        helpers:CursorHelper.IsHandCursor="True"
                        Style="{StaticResource HeaderButtonStyle}"/>
            </Grid>

            <!-- Splitter 4: Size | Type -->
            <controls:GridSplitter x:Name="Splitter4" Grid.Column="8"
                                   Width="2" Padding="0" Margin="0"
                                   ResizeDirection="Columns"
                                   HorizontalAlignment="Center"
                                   Background="Transparent" Opacity="0.3"/>

            <!-- Type Header -->
            <Grid Grid.Column="9">
                <Button x:Name="TypeHeaderButton"
                        Content="Type"
                        Click="OnHeaderClick"
                        Tag="Type"
                        helpers:CursorHelper.IsHandCursor="True"
                        Style="{StaticResource HeaderButtonStyle}"/>
            </Grid>
        </Grid>

        <!-- Item List -->
        <Grid Grid.Row="1" x:Name="ListViewWrapper"
              Loaded="OnListViewWrapperLoaded" Unloaded="OnListViewWrapperUnloaded">
        <ListView x:Name="RecycleBinListView"
                  SelectionMode="Extended"
                  CanDragItems="False"
                  AllowDrop="False"
                  SelectionChanged="OnSelectionChanged"
                  RightTapped="OnItemRightTapped"
                  DoubleTapped="OnItemDoubleTapped"
                  ContainerContentChanging="OnContainerContentChanging"
                  Background="Transparent"
                  Padding="0">
            <ListView.ItemContainerStyle>
                <StaticResource ResourceKey="DetailsItemStyle"/>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:RecycleBinItem">
                    <Grid Height="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <FontIcon Grid.Column="0" FontFamily="{StaticResource RemixIcons}"
                                  Glyph="{x:Bind IconGlyph}"
                                  FontSize="16"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Name -->
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Name}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   FontSize="13"
                                   Padding="6,0"/>

                        <!-- Original Location -->
                        <Border Grid.Column="2" x:Name="OrigLocationCell" Width="200">
                            <TextBlock Text="{x:Bind OriginalLocation}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="12"
                                       Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                       Padding="6,0"/>
                        </Border>

                        <!-- Date Deleted -->
                        <Border Grid.Column="3" x:Name="DateDeletedCell" Width="200">
                            <TextBlock VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="12"
                                       Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                       Padding="6,0"/>
                        </Border>

                        <!-- Size -->
                        <Border Grid.Column="4" x:Name="SizeCell" Width="100">
                            <TextBlock VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="12"
                                       Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                       Padding="6,0"/>
                        </Border>

                        <!-- Type -->
                        <Border Grid.Column="5" x:Name="TypeCell" Width="150">
                            <TextBlock Text="{x:Bind ItemType}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="12"
                                       Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                       Padding="6,0"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        </Grid>

        <!-- Empty State -->
        <StackPanel x:Name="EmptyState" Grid.Row="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="8" Visibility="Collapsed">
            <FontIcon Glyph="&#xE74D;" FontSize="48"
                      Foreground="{ThemeResource SpanTextTertiaryBrush}"
                      HorizontalAlignment="Center"/>
            <TextBlock x:Name="EmptyStateText" Text="Recycle Bin is empty" FontSize="14"
                       Foreground="{ThemeResource SpanTextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

    </Grid>
</UserControl>
