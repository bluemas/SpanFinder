<Window
    x:Class="Span.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Span"
    xmlns:models="using:Span.Models"
    xmlns:viewmodels="using:Span.ViewModels"
    xmlns:views="using:Span.Views"
    xmlns:helpers="using:Span.Helpers"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:spancontrols="using:Span.Views.Controls"
    xmlns:appcontrols="using:Span.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource SpanBgMicaBrush}">
        <Grid.Resources>
            <!-- FileIconConverter removed: icons are now in ViewModels -->
            <helpers:BoolToBrushConverter x:Key="BoolToBrushConverter"
                                          TrueBrush="{ThemeResource SpanAccentDimBrush}"
                                          FalseBrush="Transparent"/>
            <helpers:BoolToThicknessConverter x:Key="BoolToThicknessConverter"
                                              TrueThickness="0,2,1,0"
                                              FalseThickness="0,2,1,0"/>
            <helpers:BoolToThicknessConverter x:Key="MillerColumnBorderConverter"
                                              TrueThickness="1"
                                              FalseThickness="1"/>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- TitleBar -->
            <RowDefinition Height="Auto"/> <!-- Unified Bar -->
            <RowDefinition Height="*"/>    <!-- Main Area -->
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- 1. Title Bar -->
        <Grid x:Name="AppTitleBar" Height="{StaticResource TitleBarHeight}" Background="{ThemeResource SpanBgLayer1Brush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="RightPaddingColumn" Width="0"/> <!-- 캡션 버튼 여백 (코드에서 설정) -->
            </Grid.ColumnDefinitions>

            <!-- Bottom border line: spans full width, active tab background covers it -->
            <Rectangle Grid.ColumnSpan="3" Height="1" VerticalAlignment="Bottom"
                       Fill="{ThemeResource SpanAccentDimBrush}"/>

            <!-- App Icon & Title -->
            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center" Margin="16,0,16,0" Spacing="8">
                <Image Source="/Assets/Square44x44Logo.png" Height="16" Width="16"/>
                <TextBlock x:Name="AppTitleText" Text="SPAN Finder" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
            </StackPanel>
            
            <!-- Dynamic Tabs -->
            <ScrollViewer x:Name="TabScrollViewer" Grid.Column="1" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Auto" VerticalScrollMode="Disabled">
                <StackPanel x:Name="TabBarContent" Orientation="Horizontal" Spacing="1">
                    <ItemsRepeater x:Name="TabRepeater" AutomationProperties.AutomationId="TabRepeater" ItemsSource="{x:Bind ViewModel.Tabs, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="0"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:TabItem">
                                <Grid Height="34" VerticalAlignment="Bottom"
                                      Background="Transparent" CornerRadius="6,6,0,0"
                                      PointerPressed="OnTabItemPointerPressed"
                                      PointerMoved="OnTabItemPointerMoved"
                                      PointerReleased="OnTabItemPointerReleased"
                                      RightTapped="OnTabRightTapped"
                                      Tag="{x:Bind}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Active tab background: fills tab and covers title bar bottom line -->
                                    <Border Grid.ColumnSpan="2" Background="{ThemeResource SpanBgLayer1Brush}"
                                            CornerRadius="6,6,0,0"
                                            Visibility="{x:Bind IsActiveVisible, Mode=OneWay}"/>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Padding="12,0,0,0">
                                        <!-- Home icon (Segoe Fluent Icons) -->
                                        <FontIcon Glyph="&#xE80F;" FontSize="14"
                                                  Foreground="{ThemeResource SpanAccentBrush}"
                                                  Visibility="{x:Bind IsHomeModeVisible, Mode=OneWay}"/>
                                        <!-- Settings icon (Segoe Fluent Icons gear) -->
                                        <FontIcon Glyph="&#xE713;" FontSize="14"
                                                  Foreground="{ThemeResource SpanAccentBrush}"
                                                  Visibility="{x:Bind IsSettingsModeVisible, Mode=OneWay}"/>
                                        <!-- ActionLog icon (clock) -->
                                        <FontIcon Glyph="&#xE81C;" FontSize="14"
                                                  Foreground="{ThemeResource SpanAccentBrush}"
                                                  Visibility="{x:Bind IsActionLogModeVisible, Mode=OneWay}"/>
                                        <!-- Folder icon (RemixIcons) -->
                                        <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Folder}" FontSize="14"
                                                  Foreground="#FFD54F"
                                                  Visibility="{x:Bind IsNotHomeModeVisible, Mode=OneWay}"/>
                                        <TextBlock Text="{x:Bind Header, Mode=OneWay}"
                                                   FontSize="12" Foreground="{ThemeResource SpanTextPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"
                                                   MaxWidth="120"/>
                                    </StackPanel>
                                    <!-- Close button -->
                                    <Button Grid.Column="1" Style="{StaticResource UnifiedButtonStyle}"
                                            Width="24" Height="24" Padding="0" MinWidth="0" MinHeight="0"
                                            Margin="0,0,4,0" VerticalAlignment="Center"
                                            Click="OnTabCloseClick" Tag="{x:Bind}">
                                        <FontIcon Glyph="&#xE711;" FontSize="9"/>
                                    </Button>
                                    <!-- Inactive tab: full box border -->
                                    <Border Grid.ColumnSpan="2" BorderBrush="{ThemeResource SpanAccentDimBrush}"
                                            BorderThickness="1" CornerRadius="6,6,0,0" IsHitTestVisible="False"
                                            Visibility="{x:Bind IsInactiveVisible, Mode=OneWay}"/>
                                    <!-- Active tab: no bottom border → connects seamlessly to toolbar -->
                                    <Border Grid.ColumnSpan="2" BorderBrush="{ThemeResource SpanAccentDimBrush}"
                                            BorderThickness="1,1,1,0" CornerRadius="6,6,0,0" IsHitTestVisible="False"
                                            Visibility="{x:Bind IsActiveVisible, Mode=OneWay}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <!-- New Tab button -->
                    <Button x:Name="NewTabButton" AutomationProperties.AutomationId="Button_NewTab" Style="{StaticResource UnifiedButtonStyle}" Width="34" Height="34" VerticalAlignment="Bottom"
                            Margin="2,0,0,0" Click="OnNewTabClick" ToolTipService.ToolTip="New Tab (Ctrl+T)">
                        <FontIcon Glyph="&#xE710;" FontSize="12"/>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Settings/ActionLog 모드: 타이틀바 하단 액센트 라인을 덮어 탭↔콘텐츠 연결감 유지
        <Border Grid.Row="1" Height="4" Background="{ThemeResource SpanBgLayer1Brush}"
                BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,0,1"
                Visibility="{x:Bind IsSettingsOrActionLogMode(ViewModel.CurrentViewMode), Mode=OneWay}"/> -->

        <!-- 2. Unified Bar (hidden in Settings mode) -->
        <Grid Grid.Row="1" Height="{StaticResource CommandBarHeight}" Background="{ThemeResource SpanBgLayer1Brush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}"
              BorderThickness="{x:Bind UnifiedBarBorderThickness(ViewModel.IsSplitViewEnabled), Mode=OneWay}" Padding="8,0"
              Visibility="{x:Bind IsNotSettingsMode(ViewModel.CurrentViewMode), Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- Nav Buttons -->
                <ColumnDefinition Width="*"/>    <!-- Address Bar -->
                <ColumnDefinition Width="Auto"/> <!-- Commands -->
            </Grid.ColumnDefinitions>

            <!-- Nav Buttons (single mode, hidden in Settings) -->
            <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,8,0"
                        Visibility="{x:Bind IsSingleNonSettingsVisible(ViewModel.IsSplitViewEnabled, ViewModel.CurrentViewMode), Mode=OneWay}">
                <Button x:Name="BackButton" AutomationProperties.AutomationId="Button_Back" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="뒤로 (Alt+Left)"
                        IsEnabled="{x:Bind ViewModel.CanGoBack, Mode=OneWay}" Click="OnGoBackClick"
                        RightTapped="OnBackButtonRightTapped">
                    <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Back}" FontSize="14"/>
                </Button>
                <Button x:Name="ForwardButton" AutomationProperties.AutomationId="Button_Forward" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="앞으로 (Alt+Right)"
                        IsEnabled="{x:Bind ViewModel.CanGoForward, Mode=OneWay}" Click="OnGoForwardClick"
                        RightTapped="OnForwardButtonRightTapped">
                    <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Forward}" FontSize="14"/>
                </Button>
                <Button x:Name="UpButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="위로" Click="OnNavigateUpClick">
                    <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Up}" FontSize="14"/>
                </Button>
            </StackPanel>

            <!-- Address Bar (single mode, hidden in Settings) -->
            <Grid x:Name="AddressBarContainer" AutomationProperties.AutomationId="AddressBar" Grid.Column="1" Height="32"
                  Background="{ThemeResource SpanBgLayer2Brush}"
                  CornerRadius="4" VerticalAlignment="Center"
                  Padding="4,0"
                  Visibility="{x:Bind IsSingleNonSettingsVisible(ViewModel.IsSplitViewEnabled, ViewModel.CurrentViewMode), Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Home icon (visible only in Home mode, controlled via code-behind) -->
                <StackPanel x:Name="HomeAddressIcon" Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Visibility="Collapsed" Margin="4,0,0,0">
                    <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Home}" FontSize="13"
                              Foreground="{ThemeResource SpanAccentBrush}"
                              VerticalAlignment="Center" Margin="0,3,0,0"/>
                    <FontIcon Glyph="&#xE76C;" FontSize="8"
                              Foreground="{ThemeResource SpanTextTertiaryBrush}"
                              VerticalAlignment="Center" Margin="4,3,2,0"/>
                </StackPanel>
                <!-- RecycleBin icon (visible only in RecycleBin mode, controlled via code-behind) -->
                <StackPanel x:Name="RecycleBinAddressIcon" Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Visibility="Collapsed" Margin="4,0,0,0">
                    <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="&#xEC2A;" FontSize="13"
                              Foreground="{ThemeResource SpanAccentBrush}"
                              VerticalAlignment="Center" Margin="0,3,0,0"/>
                    <FontIcon Glyph="&#xE76C;" FontSize="8"
                              Foreground="{ThemeResource SpanTextTertiaryBrush}"
                              VerticalAlignment="Center" Margin="4,3,2,0"/>
                </StackPanel>

                <appcontrols:AddressBarControl x:Name="MainAddressBar" Grid.Column="1"
                    BreadcrumbSegmentClicked="OnAddressBarBreadcrumbClicked"
                    BreadcrumbChevronClicked="OnAddressBarChevronClicked"
                    PathNavigated="OnAddressBarPathNavigated"/>

                <!-- 경로 복사 버튼 -->
                <Button x:Name="CopyPathButton" AutomationProperties.AutomationId="Button_CopyPath" Grid.Column="2"
                        Style="{StaticResource UnifiedButtonStyle}"
                        ToolTipService.ToolTip="경로 복사"
                        Click="OnCopyPathClick"
                        Padding="4,4" MinWidth="0" MinHeight="0"
                        Margin="4,0,0,0">
                    <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Copy}" FontSize="12"/>
                </Button>
            </Grid>

            <!-- Commands -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" Margin="8,0,0,0">
                <!-- ═══ Normal Commands (hidden in RecycleBin/Settings/ActionLog) ═══ -->
                <StackPanel Orientation="Horizontal" Spacing="2"
                            Visibility="{x:Bind IsNotSpecialMode(ViewModel.CurrentViewMode), Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="0"
                                Background="Transparent" CornerRadius="4">
                        <Button x:Name="NewFolderButton" Style="{StaticResource UnifiedButtonStyle}"
                                ToolTipService.ToolTip="새 폴더 (Ctrl+Shift+N)"
                                Click="OnNewFolderClick"
                                Padding="8,4,4,4">
                            <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_NewFolder}" FontSize="16"/>
                        </Button>
                        <Button x:Name="NewItemDropdown" AutomationProperties.AutomationId="Button_NewItemDropdown"
                                Style="{StaticResource UnifiedButtonStyle}"
                                ToolTipService.ToolTip="새로 만들기..."
                                Click="OnNewItemDropdownClick"
                                Padding="2,4,4,4"
                                MinWidth="0">
                            <FontIcon Glyph="&#xE70D;" FontSize="8"/>
                        </Button>
                    </StackPanel>
                    <Rectangle Width="1" Height="20" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="4,0"/>
                    <Button x:Name="ToolbarCutButton" AutomationProperties.AutomationId="Button_Cut" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="잘라내기 (Ctrl+X)" Click="OnCutClick" IsEnabled="False"><FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Cut}"/></Button>
                    <Button x:Name="ToolbarCopyButton" AutomationProperties.AutomationId="Button_Copy" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="복사 (Ctrl+C)" Click="OnCopyClick" IsEnabled="False"><FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Copy}"/></Button>
                    <Button x:Name="ToolbarPasteButton" AutomationProperties.AutomationId="Button_Paste" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="붙여넣기 (Ctrl+V)" Click="OnPasteClick" IsEnabled="False"><FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Paste}"/></Button>
                    <Button x:Name="ToolbarRenameButton" AutomationProperties.AutomationId="Button_Rename" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="이름 바꾸기 (F2)" Click="OnRenameClick" IsEnabled="False"><FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Rename}"/></Button>
                    <Button x:Name="ToolbarDeleteButton" AutomationProperties.AutomationId="Button_Delete" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="삭제 (Del)" Click="OnDeleteClick" IsEnabled="False"><FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Delete}"/></Button>
                    <Rectangle Width="1" Height="20" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="4,0"/>

                <!-- Sort Button with Dropdown -->
                    <Button x:Name="SortButton" AutomationProperties.AutomationId="Button_Sort" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="정렬"
                            Visibility="{x:Bind IsNotSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}">
                        <Button.Flyout>
                            <MenuFlyout Placement="Bottom" Opening="OnSortMenuOpening">
                                <MenuFlyoutItem x:Name="SortByNameItem" Text="이름" Click="OnSortByName"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C1;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="SortByDateItem" Text="날짜" Click="OnSortByDate"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE787;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="SortBySizeItem" Text="크기" Click="OnSortBySize"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE91B;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="SortByTypeItem" Text="종류" Click="OnSortByType"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8FD;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem x:Name="SortAscendingItem" Text="오름차순" Click="OnSortAscending"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74A;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="SortDescendingItem" Text="내림차순" Click="OnSortDescending"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74B;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutSubItem x:Name="GroupBySubMenu" Text="그룹화"><MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xF168;"/></MenuFlyoutSubItem.Icon>
                                    <MenuFlyoutItem x:Name="GroupByNoneItem" Text="없음" Click="OnGroupByNone"/>
                                    <MenuFlyoutItem x:Name="GroupByNameItem" Text="이름" Click="OnGroupByName"/>
                                    <MenuFlyoutItem x:Name="GroupByTypeItem" Text="종류" Click="OnGroupByType"/>
                                    <MenuFlyoutItem x:Name="GroupByDateItem" Text="날짜" Click="OnGroupByDate"/>
                                    <MenuFlyoutItem x:Name="GroupBySizeItem" Text="크기" Click="OnGroupBySize"/>
                                </MenuFlyoutSubItem>
                            </MenuFlyout>
                        </Button.Flyout>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon x:Name="SortIcon" FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Sort}" FontSize="14"/>
                            <FontIcon x:Name="SortDirectionIcon" Glyph="&#xE74A;" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ViewModeButton" AutomationProperties.AutomationId="Button_ViewMode" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="보기 전환"
                            Visibility="{x:Bind IsNotSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}">
                        <Button.Flyout>
                            <MenuFlyout Placement="Bottom" Opening="OnMainViewModeMenuOpening">
                                <MenuFlyoutItem x:Name="MainVm_Miller" Text="Miller Columns" Click="OnViewModeMillerColumns"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xF0E2;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutItem x:Name="MainVm_Details" Text="Details" Click="OnViewModeDetails"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8EF;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem x:Name="MainVm_List" Text="List" Click="OnViewModeList"><MenuFlyoutItem.Icon><FontIcon Glyph="&#xE80A;"/></MenuFlyoutItem.Icon></MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutSubItem x:Name="MainVm_Icons" Text="Icons"><MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE91B;"/></MenuFlyoutSubItem.Icon>
                                    <MenuFlyoutItem x:Name="MainVm_ExtraLarge" Text="Extra Large Icons" Click="OnViewModeIconExtraLarge"/>
                                    <MenuFlyoutItem x:Name="MainVm_Large" Text="Large Icons" Click="OnViewModeIconLarge"/>
                                    <MenuFlyoutItem x:Name="MainVm_Medium" Text="Medium Icons" Click="OnViewModeIconMedium"/>
                                    <MenuFlyoutItem x:Name="MainVm_Small" Text="Small Icons" Click="OnViewModeIconSmall"/>
                                </MenuFlyoutSubItem>
                            </MenuFlyout>
                        </Button.Flyout>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon x:Name="ViewModeIcon" Glyph="&#xF0E2;" FontSize="14"/>
                            <FontIcon Glyph="&#xE70D;" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="PreviewToggleButton" AutomationProperties.AutomationId="Button_PreviewToggle" Style="{StaticResource UnifiedButtonStyle}"
                            ToolTipService.ToolTip="미리보기 패널 (Ctrl+Shift+P)" Click="OnPreviewToggleClick"
                            Visibility="{x:Bind IsNotSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}">
                        <FontIcon x:Name="PreviewToggleIcon" Glyph="&#xE8A0;" FontSize="14"/>
                    </Button>
                    <Rectangle Width="1" Height="20" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="4,0"
                               Visibility="{x:Bind IsNotSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}"/>
                    <Button x:Name="SplitViewButton" AutomationProperties.AutomationId="Button_SplitView" Style="{StaticResource UnifiedButtonStyle}"
                            ToolTipService.ToolTip="Split View (Ctrl+Shift+E)" Click="OnSplitViewToggleClick"
                            Visibility="{x:Bind IsNotSpecialMode(ViewModel.CurrentViewMode), Mode=OneWay}">
                        <FontIcon x:Name="SplitViewIcon" FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_SplitView}" FontSize="16"/>
                    </Button>
                </StackPanel>

                <!-- ═══ RecycleBin Commands (icon-only, shown in RecycleBin mode) ═══ -->
                <StackPanel Orientation="Horizontal" Spacing="2"
                            Visibility="{x:Bind helpers:StatusBarHelper.ShowIfRecycleBin(ViewModel.CurrentViewMode), Mode=OneWay}">
                    <Button x:Name="ToolbarRestoreButton" Style="{StaticResource UnifiedButtonStyle}"
                            Click="OnRecycleBinToolbarRestoreClick" IsEnabled="False"
                            ToolTipService.ToolTip="복원 (Ctrl+Z)">
                        <FontIcon Glyph="&#xE845;" FontSize="14"/>
                    </Button>
                    <Button x:Name="ToolbarDeletePermButton" Style="{StaticResource UnifiedButtonStyle}"
                            Click="OnRecycleBinToolbarDeleteClick" IsEnabled="False"
                            ToolTipService.ToolTip="영구 삭제 (Delete)">
                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                    </Button>
                    <Rectangle Width="1" Height="20" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="4,0"/>
                    <Button x:Name="ToolbarEmptyBinButton" Style="{StaticResource UnifiedButtonStyle}"
                            Click="OnRecycleBinToolbarEmptyClick"
                            ToolTipService.ToolTip="휴지통 비우기">
                        <FontIcon Glyph="&#xE894;" FontSize="14"
                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                    </Button>
                    <Rectangle Width="1" Height="20" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="4,0"/>
                    <Button Style="{StaticResource UnifiedButtonStyle}"
                            Click="OnRecycleBinToolbarRefreshClick"
                            ToolTipService.ToolTip="새로고침 (F5)">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    </Button>
                </StackPanel>

                <!-- ═══ Search Box (always visible) ═══ -->
                <Rectangle Width="1" Height="20" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="4,0"/>
                <TextBox x:Name="SearchBox" AutomationProperties.AutomationId="TextBox_Search" Width="220" Height="28" FontSize="12"
                         PlaceholderText="Search (kind: size: ext: date:)"
                         ToolTipService.ToolTip="Advanced search syntax:&#x0a;  kind:image  kind:video  kind:document&#x0a;  size:&gt;1MB  size:&lt;100KB  size:large&#x0a;  date:today  date:thisweek  date:&gt;2024-01-01&#x0a;  ext:.pdf  ext:.txt&#x0a;Combine: kind:image size:&gt;1MB"
                         KeyDown="OnSearchBoxKeyDown"/>
            </StackPanel>
        </Grid>

        <!-- 3. Main Area (Sidebar + Splitter + Content) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarCol" Width="200"/> <!-- Sidebar -->
                <ColumnDefinition x:Name="SidebarSplitterCol" Width="Auto"/> <!-- Splitter -->
                <ColumnDefinition Width="*"/>   <!-- Content -->
            </Grid.ColumnDefinitions>

            <!-- Sidebar - Hybrid 3-Section Layout -->
            <Border x:Name="SidebarBorder" AutomationProperties.AutomationId="Sidebar" Grid.Column="0" Background="{ThemeResource SpanBgLayer1Brush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              RightTapped="OnSidebarEmptyRightTapped">
                    <StackPanel Padding="0,12">

                        <!-- Section 1: 홈 -->
                        <Grid Height="28" Padding="12,0" Background="Transparent"
                              Tapped="OnHomeItemTapped"
                              PointerEntered="OnSidebarItemPointerEntered"
                              PointerExited="OnSidebarItemPointerExited">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE80F;" FontSize="16" Foreground="{ThemeResource SpanAccentBrush}" Margin="0,0,12,0"/>
                            <TextBlock x:Name="SidebarHomeText" Grid.Column="1" Text="홈" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>

                        <!-- Separator -->
                        <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="12,12"/>

                        <!-- Section 2: 즐겨찾기 (Drop Target) -->
                        <StackPanel AllowDrop="True"
                                    DragOver="OnFavoritesDragOver"
                                    Drop="OnFavoritesDrop">
                        <TextBlock x:Name="SidebarFavoritesText" Text="즐겨찾기"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                   FontWeight="SemiBold"
                                   Margin="16,0,16,8"/>

                        <!-- Flat Favorites List (default, no tree expansion) -->
                        <ListView x:Name="FavoritesFlatList"
                                  ItemsSource="{x:Bind ViewModel.Favorites, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  ItemClick="OnFavoritesFlatItemClick"
                                  CanDragItems="True"
                                  CanReorderItems="True"
                                  AllowDrop="True"
                                  DragItemsCompleted="OnFavoritesDragCompleted"
                                  RightTapped="OnFavoritesFlatListRightTapped"
                                  ContainerContentChanging="OnSidebarContainerContentChanging">
                            <ListView.Resources>
                                <!-- 커스텀 Grid 호버 사용: ListViewItem 자체 hover 배경 투명화 -->
                                <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent"/>
                                <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent"/>
                            </ListView.Resources>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="helpers:CursorHelper.IsHandCursor" Value="True"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:FavoriteItem">
                                    <Grid Height="26" Padding="12,0,8,0"
                                          Background="Transparent"
                                          ToolTipService.ToolTip="{x:Bind Path}"
                                          PointerEntered="OnSidebarItemPointerEntered"
                                          PointerExited="OnSidebarItemPointerExited">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind IconGlyph}"
                                                   FontFamily="{StaticResource RemixIcons}"
                                                   FontSize="16"
                                                   Foreground="{x:Bind IconBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Name}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Favorites Tree (expandable sidebar tree with lazy-loaded subfolders) -->
                        <TreeView x:Name="FavoritesTreeView"
                                  Visibility="Collapsed"
                                  SelectionMode="Single"
                                  ItemInvoked="OnFavoritesTreeItemInvoked"
                                  Expanding="OnFavoritesTreeExpanding"
                                  RightTapped="OnFavoritesTreeRightTapped"
                                  CanDragItems="False"
                                  CanReorderItems="False">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="MinHeight" Value="26"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="helpers:CursorHelper.IsHandCursor" Value="True"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <DataTemplate x:DataType="TreeViewNode">
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                ToolTipService.ToolTip="{Binding Content.Path}">
                                        <TextBlock Text="{Binding Content.IconGlyph}"
                                                   FontFamily="{StaticResource RemixIcons}"
                                                   FontSize="16"
                                                   Foreground="{Binding Content.IconBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Content.Name}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                        </StackPanel>

                        <!-- ═══════ Section 3: 로컬 디스크 ═══════ -->
                        <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="12,12"/>
                        <Grid Height="24" Padding="12,0" Background="Transparent"
                              Tapped="OnSidebarSectionHeaderTapped" Tag="Local"
                              PointerEntered="OnSidebarItemPointerEntered" PointerExited="OnSidebarItemPointerExited">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE70D;" FontSize="10" Margin="0,0,6,0"
                                      VerticalAlignment="Center"
                                      RenderTransformOrigin="0.5,0.5">
                                <FontIcon.RenderTransform>
                                    <RotateTransform Angle="{x:Bind helpers:ConverterHelpers.ChevronAngle(ViewModel.IsLocalDrivesExpanded), Mode=OneWay}"/>
                                </FontIcon.RenderTransform>
                            </FontIcon>
                            <TextBlock x:Name="SidebarLocalDrivesText" Grid.Column="1" Text="로컬 디스크"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SpanTextTertiaryBrush}" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Drives, Mode=OneWay}"
                                      Visibility="{x:Bind ViewModel.IsLocalDrivesExpanded, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DriveItem">
                                    <Grid Height="26" Padding="12,0,8,0" Background="Transparent"
                                          ToolTipService.ToolTip="{x:Bind TooltipText}"
                                          Tapped="OnDriveItemTapped" RightTapped="OnSidebarDriveRightTapped"
                                          PointerEntered="OnSidebarItemPointerEntered" PointerExited="OnSidebarItemPointerExited">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind IconGlyph}"
                                                   FontFamily="{StaticResource RemixIcons}" FontSize="16"
                                                   Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontSize="13"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- ═══════ Section 4: 클라우드 (CloudDrives 있을 때만) ═══════ -->
                        <StackPanel Visibility="{x:Bind ViewModel.HasCloudDrives, Mode=OneWay}">
                            <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="12,12"/>
                            <Grid Height="24" Padding="12,0" Background="Transparent"
                                  Tapped="OnSidebarSectionHeaderTapped" Tag="Cloud"
                                  PointerEntered="OnSidebarItemPointerEntered" PointerExited="OnSidebarItemPointerExited">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE70D;" FontSize="10" Margin="0,0,6,0"
                                          VerticalAlignment="Center"
                                          RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="{x:Bind helpers:ConverterHelpers.ChevronAngle(ViewModel.IsCloudDrivesExpanded), Mode=OneWay}"/>
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                                <TextBlock x:Name="SidebarCloudText" Grid.Column="1" Text="클라우드"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SpanTextTertiaryBrush}" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <ItemsControl ItemsSource="{x:Bind ViewModel.CloudDrives, Mode=OneWay}"
                                          Visibility="{x:Bind ViewModel.IsCloudDrivesExpanded, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:DriveItem">
                                        <Grid Height="26" Padding="12,0,8,0" Background="Transparent"
                                              ToolTipService.ToolTip="{x:Bind TooltipText}"
                                              Tapped="OnDriveItemTapped" RightTapped="OnSidebarDriveRightTapped"
                                              PointerEntered="OnSidebarItemPointerEntered" PointerExited="OnSidebarItemPointerExited">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind IconGlyph}"
                                                       FontFamily="{StaticResource RemixIcons}" FontSize="16"
                                                       Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontSize="13"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- ═══════ Section 5: 네트워크 (NetworkAndRemoteDrives 있을 때만) ═══════ -->
                        <StackPanel Visibility="{x:Bind ViewModel.HasNetworkDrives, Mode=OneWay}">
                            <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="12,12"/>
                            <Grid Height="24" Padding="12,0" Background="Transparent"
                                  Tapped="OnSidebarSectionHeaderTapped" Tag="Network"
                                  PointerEntered="OnSidebarItemPointerEntered" PointerExited="OnSidebarItemPointerExited">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE70D;" FontSize="10" Margin="0,0,6,0"
                                          VerticalAlignment="Center"
                                          RenderTransformOrigin="0.5,0.5">
                                    <FontIcon.RenderTransform>
                                        <RotateTransform Angle="{x:Bind helpers:ConverterHelpers.ChevronAngle(ViewModel.IsNetworkDrivesExpanded), Mode=OneWay}"/>
                                    </FontIcon.RenderTransform>
                                </FontIcon>
                                <TextBlock x:Name="SidebarNetworkText" Grid.Column="1" Text="네트워크"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SpanTextTertiaryBrush}" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <ItemsControl ItemsSource="{x:Bind ViewModel.NetworkAndRemoteDrives, Mode=OneWay}"
                                          Visibility="{x:Bind ViewModel.IsNetworkDrivesExpanded, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:DriveItem">
                                        <Grid Height="26" Padding="12,0,8,0" Background="Transparent"
                                              ToolTipService.ToolTip="{x:Bind TooltipText}"
                                              Tapped="OnDriveItemTapped" RightTapped="OnSidebarDriveRightTapped"
                                              PointerEntered="OnSidebarItemPointerEntered" PointerExited="OnSidebarItemPointerExited">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0" Width="16" Height="16"
                                                  VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="{x:Bind IconGlyph}"
                                                           FontFamily="{StaticResource RemixIcons}" FontSize="16"
                                                           Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <!-- 잠금 뱃지: 인증 필요 시 표시 -->
                                                <FontIcon Glyph="&#xE72E;" FontSize="7"
                                                          Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                          HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                          Margin="0,0,-4,-4"
                                                          Visibility="{x:Bind AuthBadgeVisibility}"/>
                                            </Grid>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontSize="13"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- ═══════ Section 6: 휴지통 ═══════ -->
                        <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="12,12"/>

                        <Grid Height="36" Padding="12,0" Background="Transparent"
                              Tapped="OnRecycleBinTapped"
                              AllowDrop="True"
                              DragOver="OnRecycleBinDragOver"
                              Drop="OnRecycleBinDrop"
                              PointerEntered="OnSidebarItemPointerEntered"
                              PointerExited="OnSidebarItemPointerExited"
                              AutomationProperties.AutomationId="Sidebar_RecycleBin">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 아이콘 (비어있음/참 전환) -->
                            <TextBlock Grid.Column="0"
                                       Text="{x:Bind ViewModel.RecycleBinIconGlyph, Mode=OneWay}"
                                       FontFamily="{StaticResource RemixIcons}" FontSize="16"
                                       Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>

                            <!-- 라벨 -->
                            <TextBlock Grid.Column="1"
                                       x:Name="RecycleBinLabel"
                                       Text="Recycle Bin" FontSize="13"
                                       VerticalAlignment="Center"/>

                            <!-- 항목 개수 배지 -->
                            <Border Grid.Column="2"
                                    Visibility="{x:Bind helpers:ConverterHelpers.NotBoolToVisibility(ViewModel.RecycleBinIsEmpty), Mode=OneWay}"
                                    Background="{ThemeResource SpanBgHoverBrush}"
                                    CornerRadius="8" Padding="6,1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.RecycleBinItemCount, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                            </Border>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>

                <!-- Sidebar bottom bar: Help, Log (left) | Settings (right) -->
                <Grid Grid.Row="1"
                      BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,1,0,0"
                      Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="0" HorizontalAlignment="Left">
                        <Button x:Name="HelpButton" AutomationProperties.AutomationId="Button_Help" Style="{StaticResource UnifiedButtonStyle}"
                                ToolTipService.ToolTip="단축키 도움말 (Shift+?)" Click="OnHelpClick"
                                Padding="6,4" MinWidth="0" MinHeight="0">
                            <FontIcon Glyph="&#xE897;" FontSize="14"/>
                        </Button>
                        <Button x:Name="LogButton" AutomationProperties.AutomationId="Button_Log" Style="{StaticResource UnifiedButtonStyle}"
                                ToolTipService.ToolTip="작업 로그" Click="OnLogClick"
                                Padding="6,4" MinWidth="0" MinHeight="0">
                            <FontIcon Glyph="&#xE81C;" FontSize="14"/>
                        </Button>
                    </StackPanel>
                    <Button x:Name="SettingsButton" AutomationProperties.AutomationId="Button_Settings" Style="{StaticResource UnifiedButtonStyle}"
                            ToolTipService.ToolTip="설정" Click="OnSettingsClick"
                            Padding="6,4" MinWidth="0" MinHeight="0"
                            HorizontalAlignment="Right">
                        <FontIcon Glyph="&#xE713;" FontSize="14"/>
                    </Button>
                </Grid>
                </Grid>
            </Border>

            <!-- Sidebar Resize Splitter: 6px drag area, visually 1px right border -->
            <Border x:Name="SidebarSplitter" Grid.Column="1" Width="6"
                    Background="{ThemeResource SpanBgLayer1Brush}"
                    BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,1,0"
                    ManipulationMode="TranslateX" ManipulationStarted="OnSidebarSplitterManipulationStarted"
                    ManipulationDelta="OnSidebarSplitterManipulationDelta"
                    PointerEntered="OnSidebarSplitterPointerEntered" PointerExited="OnSidebarSplitterPointerExited"/>


            <!-- Content (Split View Container) -->
            <Grid Grid.Column="2" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="SplitterCol" Width="0"/>
                    <ColumnDefinition x:Name="RightPaneCol" Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- ===== LEFT PANE ===== -->
                <Grid x:Name="LeftPaneContainer" AutomationProperties.AutomationId="LeftPane" Grid.Column="0" GotFocus="OnLeftPaneGotFocus"
                      Background="Transparent"
                      AllowDrop="True" DragOver="OnPaneDragOver" Drop="OnPaneDrop" DragLeave="OnPaneDragLeave">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/> <!-- FilterBar -->
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/> <!-- Git Status Bar -->
                    </Grid.RowDefinitions>

                    <!-- Drop overlay (cross-pane visual feedback) -->
                    <Border x:Name="LeftDropOverlay" Grid.RowSpan="4" Opacity="0" IsHitTestVisible="False"
                            Background="{ThemeResource SpanAccentBrush}" CornerRadius="4" Margin="4"/>

                    <!-- Left Pane Path Header (split mode, hidden in Home) -->
                    <Grid Grid.Row="0" x:Name="LeftPathHeader" Height="32"
                          Visibility="{x:Bind IsLeftPaneHeaderVisible(ViewModel.IsSplitViewEnabled, ViewModel.CurrentViewMode), Mode=OneWay}"
                          Background="{ThemeResource SpanBgLayer2Brush}"
                          BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,0,1"
                          Tapped="OnLeftPaneHeaderTapped">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- Nav buttons -->
                            <ColumnDefinition Width="*"/>     <!-- Breadcrumb -->
                            <ColumnDefinition Width="Auto"/>  <!-- Copy path -->
                        </Grid.ColumnDefinitions>
                        <!-- Active pane accent bar -->
                        <Rectangle Height="1" VerticalAlignment="Top" Grid.ColumnSpan="3"
                                   Fill="{ThemeResource SpanAccentBrush}"
                                   Opacity="{x:Bind LeftPaneAccentOpacity(ViewModel.ActivePane), Mode=OneWay}"/>
                        <!-- Nav buttons -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center" Margin="2,0,0,0">
                            <Button x:Name="LeftBackButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="뒤로 (Alt+Left)"
                                    Tag="Left" Click="OnPaneGoBackClick"
                                    RightTapped="OnPaneBackButtonRightTapped"
                                    IsEnabled="{x:Bind ViewModel.CanGoBack, Mode=OneWay}"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE72B;" FontSize="11"/>
                            </Button>
                            <Button x:Name="LeftForwardButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="앞으로 (Alt+Right)"
                                    Tag="Left" Click="OnPaneGoForwardClick"
                                    RightTapped="OnPaneForwardButtonRightTapped"
                                    IsEnabled="{x:Bind ViewModel.CanGoForward, Mode=OneWay}"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE72A;" FontSize="11"/>
                            </Button>
                            <Button x:Name="LeftUpButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="위로"
                                    Tag="Left" Click="OnPaneNavigateUpClick"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE74A;" FontSize="11"/>
                            </Button>
                        </StackPanel>
                        <!-- Breadcrumb + Edit mode -->
                        <appcontrols:AddressBarControl x:Name="LeftAddressBar" Grid.Column="1" 
                            BreadcrumbSegmentClicked="OnAddressBarBreadcrumbClicked"
                            BreadcrumbChevronClicked="OnAddressBarChevronClicked"
                            PathNavigated="OnAddressBarPathNavigated"/>
                        <!-- Pane actions: CopyPath | Sort, ViewMode, Preview -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center" Margin="0,0,2,0">
                            <!-- CopyPath -->
                            <Button x:Name="LeftCopyPathButton" Style="{StaticResource UnifiedButtonStyle}"
                                    ToolTipService.ToolTip="경로 복사" Tag="Left" Click="OnPaneCopyPathClick"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE8C8;" FontSize="11"/>
                            </Button>
                            <Rectangle Width="1" Height="16" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="2,0" VerticalAlignment="Center"/>
                            <!-- Sort -->
                            <Button x:Name="LeftSortButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="정렬"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <Button.Flyout>
                                    <MenuFlyout Placement="Bottom" Opening="OnLeftPaneSortMenuOpening">
                                        <MenuFlyoutItem x:Name="LeftSortByNameItem" Text="이름" Click="OnSortByName">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C1;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="LeftSortByDateItem" Text="날짜" Click="OnSortByDate">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE787;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="LeftSortBySizeItem" Text="크기" Click="OnSortBySize">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE91B;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="LeftSortByTypeItem" Text="종류" Click="OnSortByType">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8FD;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem x:Name="LeftSortAscendingItem" Text="오름차순" Click="OnSortAscending">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74A;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="LeftSortDescendingItem" Text="내림차순" Click="OnSortDescending">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74B;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                                <FontIcon Glyph="&#xE8CB;" FontSize="11"/>
                            </Button>
                            <!-- ViewMode -->
                            <Button x:Name="LeftViewModeButton" AutomationProperties.AutomationId="Button_LeftViewMode" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="보기 전환"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <Button.Flyout>
                                    <MenuFlyout Placement="Bottom" Opening="OnLeftPaneViewModeMenuOpening">
                                        <MenuFlyoutItem x:Name="LeftVm_Miller" Text="Miller Columns" Click="OnViewModeMillerColumns">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xF0E2;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="LeftVm_Details" Text="Details" Click="OnViewModeDetails">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8EF;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="LeftVm_List" Text="List" Click="OnViewModeList">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE80A;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutSubItem x:Name="LeftVm_Icons" Text="Icons">
                                            <MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE91B;"/></MenuFlyoutSubItem.Icon>
                                            <MenuFlyoutItem x:Name="LeftVm_ExtraLarge" Text="Extra Large Icons" Click="OnViewModeIconExtraLarge"/>
                                            <MenuFlyoutItem x:Name="LeftVm_Large" Text="Large Icons" Click="OnViewModeIconLarge"/>
                                            <MenuFlyoutItem x:Name="LeftVm_Medium" Text="Medium Icons" Click="OnViewModeIconMedium"/>
                                            <MenuFlyoutItem x:Name="LeftVm_Small" Text="Small Icons" Click="OnViewModeIconSmall"/>
                                        </MenuFlyoutSubItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                                <FontIcon x:Name="LeftViewModeIcon" Glyph="&#xF0E2;" FontSize="11"/>
                            </Button>
                            <!-- Preview -->
                            <Button x:Name="LeftPreviewButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="미리보기 패널"
                                    Tag="Left" Click="OnPanePreviewToggle"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon x:Name="LeftPreviewIcon" Glyph="&#xE8A0;" FontSize="11"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Filter Bar (Ctrl+Shift+F) -->
                    <Grid x:Name="LeftFilterBar" Grid.Row="1" Height="32" Visibility="Collapsed"
                          Background="{ThemeResource SpanBgLayer2Brush}"
                          BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- Filter icon -->
                            <ColumnDefinition Width="*"/>     <!-- TextBox -->
                            <ColumnDefinition Width="Auto"/>  <!-- Count -->
                            <ColumnDefinition Width="Auto"/>  <!-- Close button -->
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE71C;" FontSize="12" Margin="10,0,6,0"
                                  Foreground="{ThemeResource SpanTextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox x:Name="LeftFilterTextBox" Grid.Column="1"
                                 PlaceholderText="&#xD544;&#xD130;... (*.txt, keyword)"
                                 Background="Transparent" BorderThickness="0"
                                 FontSize="12" VerticalAlignment="Center"
                                 TextChanged="OnFilterTextChanged"
                                 KeyDown="OnFilterTextBoxKeyDown"/>
                        <TextBlock x:Name="LeftFilterCountText" Grid.Column="2"
                                   FontSize="11" Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="4,0"/>
                        <Button Grid.Column="3" Style="{StaticResource UnifiedButtonStyle}"
                                ToolTipService.ToolTip="&#xD544;&#xD130; &#xB2EB;&#xAE30; (Esc)"
                                Click="OnFilterBarClose"
                                Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26"
                                Margin="0,0,4,0" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE711;" FontSize="10"/>
                        </Button>
                    </Grid>

                    <!-- Left Pane Content -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition x:Name="LeftPreviewSplitterCol" Width="0"/>
                            <ColumnDefinition x:Name="LeftPreviewCol" Width="0"/>
                        </Grid.ColumnDefinitions>

                        <!-- Explorer Views -->
                        <Grid Grid.Column="0">
                            <!-- Miller Columns Host — 탭별 패널을 Show/Hide로 전환 -->
                            <Grid x:Name="MillerTabsHost" AutomationProperties.AutomationId="Host_Miller">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- 첫 번째 탭 전용 (XAML 정의) — 추가 탭은 코드에서 동적 생성 -->
                                <ScrollViewer x:Name="MillerScrollViewer" Grid.Column="0"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled"
                                              VerticalScrollMode="Disabled"
                                              >
                                    <StackPanel Orientation="Horizontal">
                                    <ItemsControl x:Name="MillerColumnsControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:FolderViewModel">
                                            <Grid Width="220" MinWidth="150">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        BorderBrush="{Binding IsActive, Converter={StaticResource BoolToBrushConverter}}"
                                                        BorderThickness="{Binding IsActive, Converter={StaticResource MillerColumnBorderConverter}}"
                                                        Background="{ThemeResource SpanBgMicaBrush}">
                                                    <Grid Loaded="OnMillerColumnContentGridLoaded" Unloaded="OnMillerColumnContentGridUnloaded"
                                                          PointerPressed="OnMillerColumnPointerPressed">
                                                            <ListView ItemsSource="{x:Bind Children, Mode=OneWay}" SelectedItem="{x:Bind SelectedChild, Mode=OneWay}"
                                                                      SelectionMode="Extended" IsItemClickEnabled="False"
                                                                      CanDragItems="True" AllowDrop="True"
                                                                      Background="Transparent"
                                                                      ItemContainerStyle="{StaticResource MillerColumnItemStyle}"
                                                                      DragItemsStarting="OnDragItemsStarting" DragItemsCompleted="OnDragItemsCompleted"
                                                                      DragOver="OnColumnDragOver" Drop="OnColumnDrop"
                                                                      GotFocus="OnMillerColumnGotFocus"
                                                                      SelectionChanged="OnMillerColumnSelectionChanged"
                                                                      DoubleTapped="OnMillerColumnDoubleTapped"
                                                                      RightTapped="OnMillerColumnEmptyAreaRightTapped"
                                                                      ContainerContentChanging="OnMillerContainerContentChanging">
                                                                <ListView.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <ItemsStackPanel CacheLength="1.0"/>
                                                                    </ItemsPanelTemplate>
                                                                </ListView.ItemsPanel>
                                                                <ListView.ItemContainerTransitions>
                                                                    <TransitionCollection/>
                                                                </ListView.ItemContainerTransitions>
                                                                <ListView.ItemTemplateSelector>
                                                                    <local:FileSystemItemTemplateSelector>
                                                                        <local:FileSystemItemTemplateSelector.FolderTemplate>
                                                                            <DataTemplate x:DataType="viewmodels:FolderViewModel">
                                                                                <Grid Padding="12,2" MinHeight="24" RightTapped="OnFolderRightTapped"
                                                                                      ToolTipService.ToolTip="{x:Bind TooltipText}"
                                                                                      Opacity="{x:Bind ItemOpacity, Mode=OneWay}"
                                                                                      AllowDrop="True" DragOver="OnFolderItemDragOver" Drop="OnFolderItemDrop" DragLeave="OnFolderItemDragLeave">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <!-- Col0: reserved for layout alignment (indicator handled by floating overlay) -->
                                                                                    <FontIcon Grid.Column="1" FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Folder}" FontSize="16" Foreground="{x:Bind IconBrush}" Margin="0,0,12,0"/>
                                                                                    <TextBlock Grid.Column="2" Text="{x:Bind TruncatedDisplayName, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="13"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <TextBox Grid.Column="2" Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                             Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                                                                                             VerticalAlignment="Center" Padding="2" MinHeight="0" FontSize="13"
                                                                                             LostFocus="OnRenameTextBoxLostFocus" KeyDown="OnRenameTextBoxKeyDown"/>
                                                                                    <!-- Item count badge -->
                                                                                    <TextBlock Grid.Column="3" Text="{x:Bind ChildCountText, Mode=OneWay}" VerticalAlignment="Center"
                                                                                               FontSize="10" Foreground="{ThemeResource SpanTextTertiaryBrush}" Margin="4,0,4,0"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <FontIcon Grid.Column="4" FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_ChevronRight}" FontSize="10" Foreground="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.5"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </local:FileSystemItemTemplateSelector.FolderTemplate>
                                                                        <local:FileSystemItemTemplateSelector.FileTemplate>
                                                                            <DataTemplate x:DataType="viewmodels:FileViewModel">
                                                                                <Grid Padding="12,2" MinHeight="24" RightTapped="OnFileRightTapped"
                                                                                      ToolTipService.ToolTip="{x:Bind TooltipText}"
                                                                                      Opacity="{x:Bind ItemOpacity, Mode=OneWay}">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <!-- Col0: path indicator placeholder (matches FolderTemplate column structure) -->
                                                                                    <Border Grid.Column="0" Width="1" CornerRadius="0.5" Margin="-8,2,0,2" Visibility="Collapsed"/>
                                                                                    <Grid Grid.Column="1" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center">
                                                                                        <!-- Opacity 전환: Visibility→Opacity로 레이아웃 패스 없이 렌더링만 전환 (14K 스크롤 지터 방지) -->
                                                                                        <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}" Stretch="UniformToFill"
                                                                                               Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfTrue(HasThumbnail), Mode=OneWay}"
                                                                                               IsHitTestVisible="False" x:Phase="1"/>
                                                                                        <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{x:Bind IconGlyph}" FontSize="16" Foreground="{x:Bind IconBrush}"
                                                                                                  Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfFalse(HasThumbnail), Mode=OneWay}"
                                                                                                  IsHitTestVisible="False"/>
                                                                                        <Border Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfTrue(HasCloudBadge), Mode=OneWay}"
                                                                                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4,-4"
                                                                                                Width="12" Height="12" CornerRadius="6"
                                                                                                Background="{x:Bind CloudBadgeBrush, Mode=OneWay}"
                                                                                                IsHitTestVisible="False" x:Phase="1">
                                                                                            <FontIcon Glyph="{x:Bind CloudStateGlyph, Mode=OneWay}" FontSize="8"
                                                                                                      Foreground="{ThemeResource SpanTextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                        <!-- Git 뱃지 (동일 위치, Git 우선 — 위에 렌더링) -->
                                                                                        <Border Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfTrue(HasGitBadge), Mode=OneWay}"
                                                                                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4,-4"
                                                                                                Width="14" Height="14" CornerRadius="7"
                                                                                                Background="{x:Bind GitStatusBrush, Mode=OneWay}"
                                                                                                IsHitTestVisible="False" x:Phase="1">
                                                                                            <TextBlock Text="{x:Bind GitStatusText, Mode=OneWay}" FontSize="8" FontWeight="Bold"
                                                                                                       Foreground="{x:Bind GitBadgeTextBrush, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                       Margin="0,-1,0,0"/>
                                                                                        </Border>
                                                                                    </Grid>
                                                                                    <TextBlock Grid.Column="2" Text="{x:Bind TruncatedDisplayName, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="13"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <TextBox Grid.Column="2" Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                             Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                                                                                             VerticalAlignment="Center" Padding="2" MinHeight="0" FontSize="13"
                                                                                             LostFocus="OnRenameTextBoxLostFocus" KeyDown="OnRenameTextBoxKeyDown"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </local:FileSystemItemTemplateSelector.FileTemplate>
                                                                    </local:FileSystemItemTemplateSelector>
                                                                </ListView.ItemTemplateSelector>
                                                            </ListView>
                                                            <!-- Loading indicator — visible while folder contents load -->
                                                            <ProgressRing IsActive="{x:Bind IsLoading, Mode=OneWay}"
                                                                          Width="20" Height="20"
                                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            <!-- Empty folder message -->
                                                            <StackPanel Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfTrue(IsEmpty), Mode=OneWay}"
                                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                        Spacing="4" Opacity="0.5">
                                                                <FontIcon Glyph="&#xE8B7;" FontSize="24"
                                                                          Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                                                          HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{x:Bind viewmodels:FolderViewModel.GetEmptyFolderText()}" FontSize="12"
                                                                           Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                                                           HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                            <!-- Error state -->
                                                            <StackPanel Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfTrue(HasError), Mode=OneWay}"
                                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                        Spacing="8" Opacity="0.7">
                                                                <FontIcon Glyph="{x:Bind ErrorIcon, Mode=OneWay}" FontSize="28"
                                                                          Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                                          HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{x:Bind ErrorMessage, Mode=OneWay}" FontSize="12"
                                                                           Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                                                           TextWrapping="Wrap" MaxWidth="200" TextAlignment="Center"
                                                                           HorizontalAlignment="Center"/>
                                                                <HyperlinkButton Content="{x:Bind viewmodels:FolderViewModel.GetRetryText()}" FontSize="11"
                                                                                 HorizontalAlignment="Center"
                                                                                 Click="OnRetryFolderLoad" Tag="{x:Bind}" />
                                                            </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <!-- Column edge shadow (depth) -->
                                                <Rectangle Grid.Column="1" Width="8" HorizontalAlignment="Left" Margin="-7,0,0,0"
                                                           Fill="{ThemeResource SpanColumnShadowBrush}" IsHitTestVisible="False"/>
                                                <!-- Column resize grip -->
                                                <Rectangle Grid.Column="1" Width="4" Fill="Transparent"
                                                           PointerEntered="OnColumnResizeGripPointerEntered"
                                                           PointerExited="OnColumnResizeGripPointerExited"
                                                           PointerPressed="OnColumnResizeGripPointerPressed"
                                                           PointerMoved="OnColumnResizeGripPointerMoved"
                                                           PointerReleased="OnColumnResizeGripPointerReleased"
                                                           DoubleTapped="OnColumnResizeGripDoubleTapped"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>

                            </Grid>

                            <!-- Details View Host — 탭별 패널을 Show/Hide로 전환 -->
                            <Grid x:Name="DetailsTabsHost" AutomationProperties.AutomationId="Host_Details" Visibility="Collapsed">
                                <views:DetailsModeView x:Name="DetailsView"/>
                            </Grid>

                            <!-- List View Host — 탭별 패널을 Show/Hide로 전환 -->
                            <Grid x:Name="ListTabsHost" AutomationProperties.AutomationId="Host_List" Visibility="Collapsed">
                                <views:ListModeView x:Name="ListView"/>
                            </Grid>

                            <!-- Icon View Host — 탭별 패널을 Show/Hide로 전환 -->
                            <Grid x:Name="IconTabsHost" AutomationProperties.AutomationId="Host_Icon" Visibility="Collapsed">
                                <views:IconModeView x:Name="IconView"/>
                            </Grid>

                            <!-- Home View (Left only) -->
                            <views:HomeModeView x:Name="HomeView"
                                                Visibility="Collapsed"/>

                            <!-- Settings View (Left only) -->
                            <views:SettingsModeView x:Name="SettingsView"
                                                    Visibility="Collapsed"/>

                            <!-- Action Log View (Left only) -->
                            <views:LogModeView x:Name="LogView"
                                               Visibility="Collapsed"/>

                            <!-- Recycle Bin View (Left only) -->
                            <views:RecycleBinModeView x:Name="RecycleBinView"
                                                      Visibility="Collapsed"/>
                        </Grid>

                        <!-- Preview Splitter (Left) -->
                        <controls:GridSplitter Grid.Column="1" Width="2"
                            Background="Transparent"
                            Visibility="{x:Bind PreviewVisible(ViewModel.IsLeftPreviewEnabled), Mode=OneWay}"/>

                        <!-- Preview Panel (Left) -->
                        <views:PreviewPanelView x:Name="LeftPreviewPanel" Grid.Column="2"
                            MinWidth="320"
                            BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1,0,0,0"
                            Visibility="{x:Bind PreviewVisible(ViewModel.IsLeftPreviewEnabled), Mode=OneWay}"/>
                    </Grid>

                    <!-- Git Status Bar (Left) -->
                    <Border x:Name="LeftGitStatusBar" Grid.Row="3" Grid.ColumnSpan="3"
                            Height="28" Background="{ThemeResource SpanBgLayer2Brush}"
                            BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,1,0,0"
                            Visibility="Collapsed">
                        <Button x:Name="LeftGitStatusButton"
                                Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="12,0" Height="28">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8AD;" FontSize="12"
                                          Foreground="{ThemeResource SpanAccentBrush}"/>
                                <TextBlock x:Name="LeftGitBranch" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Rectangle Width="1" Height="14" Fill="{ThemeResource SpanBorderSubtleBrush}"
                                           Margin="4,0"/>
                                <TextBlock x:Name="LeftGitStatus" FontSize="12" Opacity="0.8"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Flyout>
                                <Flyout Placement="TopEdgeAlignedRight">
                                    <StackPanel Width="320" Spacing="12" Padding="4">
                                        <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE8AD;" FontSize="14"
                                                          Foreground="{ThemeResource SpanAccentBrush}"/>
                                                <TextBlock x:Name="LeftFlyoutBranch" FontSize="14"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <TextBlock x:Name="LeftFlyoutStatus" FontSize="12" Opacity="0.8"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="LeftFlyoutCommitsLabel" FontSize="11"
                                                       FontWeight="SemiBold" Opacity="0.6"/>
                                            <TextBlock x:Name="LeftFlyoutCommits"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="LeftFlyoutFilesLabel" FontSize="11"
                                                       FontWeight="SemiBold" Opacity="0.6"/>
                                            <ScrollViewer MaxHeight="200">
                                                <TextBlock x:Name="LeftFlyoutFiles"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="11"/>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Border>
                </Grid>

                <!-- ===== RIGHT PANE ===== -->
                <Grid x:Name="RightPaneContainer" AutomationProperties.AutomationId="RightPane" Grid.Column="2" GotFocus="OnRightPaneGotFocus"
                      Background="Transparent" Margin="1,0,0,0"
                      AllowDrop="True" DragOver="OnPaneDragOver" Drop="OnPaneDrop" DragLeave="OnPaneDragLeave"
                      Visibility="{x:Bind IsSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/> <!-- Git Status Bar -->
                    </Grid.RowDefinitions>

                    <!-- Drop overlay (cross-pane visual feedback) -->
                    <Border x:Name="RightDropOverlay" Grid.RowSpan="3" Opacity="0" IsHitTestVisible="False"
                            Background="{ThemeResource SpanAccentBrush}" CornerRadius="4" Margin="4"/>

                    <!-- Right Pane Path Header -->
                    <Grid Grid.Row="0" x:Name="RightPathHeader" Height="32"
                          Background="{ThemeResource SpanBgLayer2Brush}"
                          BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,0,1"
                          Tapped="OnRightPaneHeaderTapped">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Active pane accent bar -->
                        <Rectangle Height="1" VerticalAlignment="Top" Grid.ColumnSpan="3"
                                   Fill="{ThemeResource SpanAccentBrush}"
                                   Opacity="{x:Bind RightPaneAccentOpacity(ViewModel.ActivePane), Mode=OneWay}"/>
                        <!-- Nav buttons -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center" Margin="2,0,0,0">
                            <Button x:Name="RightBackButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="뒤로 (Alt+Left)"
                                    Tag="Right" Click="OnPaneGoBackClick"
                                    RightTapped="OnPaneBackButtonRightTapped"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE72B;" FontSize="11"/>
                            </Button>
                            <Button x:Name="RightForwardButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="앞으로 (Alt+Right)"
                                    Tag="Right" Click="OnPaneGoForwardClick"
                                    RightTapped="OnPaneForwardButtonRightTapped"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE72A;" FontSize="11"/>
                            </Button>
                            <Button x:Name="RightUpButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="위로"
                                    Tag="Right" Click="OnPaneNavigateUpClick"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE74A;" FontSize="11"/>
                            </Button>
                        </StackPanel>
                        <!-- Breadcrumb + Edit mode -->
                        <appcontrols:AddressBarControl x:Name="RightAddressBar" Grid.Column="1" 
                            BreadcrumbSegmentClicked="OnAddressBarBreadcrumbClicked"
                            BreadcrumbChevronClicked="OnAddressBarChevronClicked"
                            PathNavigated="OnAddressBarPathNavigated"/>
                        <!-- Pane actions: CopyPath | Sort, ViewMode, Preview -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center" Margin="0,0,2,0">
                            <!-- CopyPath -->
                            <Button x:Name="RightCopyPathButton" Style="{StaticResource UnifiedButtonStyle}"
                                    ToolTipService.ToolTip="경로 복사" Tag="Right" Click="OnPaneCopyPathClick"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE8C8;" FontSize="11"/>
                            </Button>
                            <Rectangle Width="1" Height="16" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="2,0" VerticalAlignment="Center"/>
                            <!-- Sort -->
                            <Button x:Name="RightSortButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="정렬"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <Button.Flyout>
                                    <MenuFlyout Placement="Bottom" Opening="OnRightPaneSortMenuOpening">
                                        <MenuFlyoutItem x:Name="RightSortByNameItem" Text="이름" Click="OnSortByName">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C1;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="RightSortByDateItem" Text="날짜" Click="OnSortByDate">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE787;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="RightSortBySizeItem" Text="크기" Click="OnSortBySize">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE91B;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="RightSortByTypeItem" Text="종류" Click="OnSortByType">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8FD;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem x:Name="RightSortAscendingItem" Text="오름차순" Click="OnSortAscending">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74A;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="RightSortDescendingItem" Text="내림차순" Click="OnSortDescending">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74B;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                                <FontIcon Glyph="&#xE8CB;" FontSize="11"/>
                            </Button>
                            <!-- ViewMode -->
                            <Button x:Name="RightViewModeButton" AutomationProperties.AutomationId="Button_RightViewMode" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="보기 전환"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <Button.Flyout>
                                    <MenuFlyout Placement="Bottom" Opening="OnRightPaneViewModeMenuOpening">
                                        <MenuFlyoutItem x:Name="RightVm_Miller" Text="Miller Columns" Click="OnViewModeMillerColumns">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xF0E2;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="RightVm_Details" Text="Details" Click="OnViewModeDetails">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8EF;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem x:Name="RightVm_List" Text="List" Click="OnViewModeList">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE80A;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutSubItem x:Name="RightVm_Icons" Text="Icons">
                                            <MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE91B;"/></MenuFlyoutSubItem.Icon>
                                            <MenuFlyoutItem x:Name="RightVm_ExtraLarge" Text="Extra Large Icons" Click="OnViewModeIconExtraLarge"/>
                                            <MenuFlyoutItem x:Name="RightVm_Large" Text="Large Icons" Click="OnViewModeIconLarge"/>
                                            <MenuFlyoutItem x:Name="RightVm_Medium" Text="Medium Icons" Click="OnViewModeIconMedium"/>
                                            <MenuFlyoutItem x:Name="RightVm_Small" Text="Small Icons" Click="OnViewModeIconSmall"/>
                                        </MenuFlyoutSubItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                                <FontIcon x:Name="RightViewModeIcon" Glyph="&#xF0E2;" FontSize="11"/>
                            </Button>
                            <!-- Preview -->
                            <Button x:Name="RightPreviewButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="미리보기 패널"
                                    Tag="Right" Click="OnPanePreviewToggle"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon x:Name="RightPreviewIcon" Glyph="&#xE8A0;" FontSize="11"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Right Pane Content -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition x:Name="RightPreviewSplitterCol" Width="0"/>
                            <ColumnDefinition x:Name="RightPreviewCol" Width="0"/>
                        </Grid.ColumnDefinitions>

                        <!-- Explorer Views -->
                        <Grid Grid.Column="0">
                            <!-- Miller Columns View (Right) -->
                            <ScrollViewer x:Name="MillerScrollViewerRight"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Visibility="{x:Bind IsMillerColumnsMode(ViewModel.RightViewMode), Mode=OneWay}">
                                <ItemsControl x:Name="MillerColumnsControlRight" ItemsSource="{x:Bind ViewModel.RightExplorer.Columns, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:FolderViewModel">
                                            <Grid Width="220" MinWidth="150">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        BorderBrush="{Binding IsActive, Converter={StaticResource BoolToBrushConverter}}"
                                                        BorderThickness="{Binding IsActive, Converter={StaticResource MillerColumnBorderConverter}}"
                                                        Background="{ThemeResource SpanBgMicaBrush}">
                                                    <Grid Loaded="OnMillerColumnContentGridLoaded" Unloaded="OnMillerColumnContentGridUnloaded"
                                                          PointerPressed="OnMillerColumnPointerPressed">
                                                            <ListView ItemsSource="{x:Bind Children, Mode=OneWay}" SelectedItem="{x:Bind SelectedChild, Mode=OneWay}"
                                                                      SelectionMode="Extended" IsItemClickEnabled="False"
                                                                      CanDragItems="True" AllowDrop="True"
                                                                      Background="Transparent"
                                                                      ItemContainerStyle="{StaticResource MillerColumnItemStyle}"
                                                                      DragItemsStarting="OnDragItemsStarting" DragItemsCompleted="OnDragItemsCompleted"
                                                                      DragOver="OnColumnDragOver" Drop="OnColumnDrop"
                                                                      GotFocus="OnMillerColumnGotFocus"
                                                                      SelectionChanged="OnMillerColumnSelectionChanged"
                                                                      DoubleTapped="OnMillerColumnDoubleTapped"
                                                                      RightTapped="OnMillerColumnEmptyAreaRightTapped"
                                                                      ContainerContentChanging="OnMillerContainerContentChanging">
                                                                <ListView.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <ItemsStackPanel CacheLength="1.0"/>
                                                                    </ItemsPanelTemplate>
                                                                </ListView.ItemsPanel>
                                                                <ListView.ItemContainerTransitions>
                                                                    <TransitionCollection/>
                                                                </ListView.ItemContainerTransitions>
                                                                <ListView.ItemTemplateSelector>
                                                                    <local:FileSystemItemTemplateSelector>
                                                                        <local:FileSystemItemTemplateSelector.FolderTemplate>
                                                                            <DataTemplate x:DataType="viewmodels:FolderViewModel">
                                                                                <Grid Padding="12,2" MinHeight="24" RightTapped="OnFolderRightTapped"
                                                                                      ToolTipService.ToolTip="{x:Bind TooltipText}"
                                                                                      Opacity="{x:Bind ItemOpacity, Mode=OneWay}"
                                                                                      AllowDrop="True" DragOver="OnFolderItemDragOver" Drop="OnFolderItemDrop" DragLeave="OnFolderItemDragLeave">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <!-- Col0: reserved for layout alignment (indicator handled by floating overlay) -->
                                                                                    <FontIcon Grid.Column="1" FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Folder}" FontSize="16" Foreground="{x:Bind IconBrush}" Margin="0,0,12,0"/>
                                                                                    <TextBlock Grid.Column="2" Text="{x:Bind TruncatedDisplayName, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="13"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <TextBox Grid.Column="2" Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                             Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                                                                                             VerticalAlignment="Center" Padding="2" MinHeight="0" FontSize="13"
                                                                                             LostFocus="OnRenameTextBoxLostFocus" KeyDown="OnRenameTextBoxKeyDown"/>
                                                                                    <!-- Item count badge -->
                                                                                    <TextBlock Grid.Column="3" Text="{x:Bind ChildCountText, Mode=OneWay}" VerticalAlignment="Center"
                                                                                               FontSize="10" Foreground="{ThemeResource SpanTextTertiaryBrush}" Margin="4,0,4,0"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <FontIcon Grid.Column="4" FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_ChevronRight}" FontSize="10" Foreground="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.5"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </local:FileSystemItemTemplateSelector.FolderTemplate>
                                                                        <local:FileSystemItemTemplateSelector.FileTemplate>
                                                                            <DataTemplate x:DataType="viewmodels:FileViewModel">
                                                                                <Grid Padding="12,2" MinHeight="24" RightTapped="OnFileRightTapped"
                                                                                      ToolTipService.ToolTip="{x:Bind TooltipText}"
                                                                                      Opacity="{x:Bind ItemOpacity, Mode=OneWay}">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <!-- Col0: path indicator placeholder (matches FolderTemplate column structure) -->
                                                                                    <Border Grid.Column="0" Width="1" CornerRadius="0.5" Margin="-8,2,0,2" Visibility="Collapsed"/>
                                                                                    <Grid Grid.Column="1" Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center">
                                                                                        <!-- Opacity 전환: Visibility→Opacity로 레이아웃 패스 없이 렌더링만 전환 (14K 스크롤 지터 방지) -->
                                                                                        <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}" Stretch="UniformToFill"
                                                                                               Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfTrue(HasThumbnail), Mode=OneWay}"
                                                                                               IsHitTestVisible="False" x:Phase="1"/>
                                                                                        <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{x:Bind IconGlyph}" FontSize="16" Foreground="{x:Bind IconBrush}"
                                                                                                  Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfFalse(HasThumbnail), Mode=OneWay}"
                                                                                                  IsHitTestVisible="False"/>
                                                                                        <Border Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfTrue(HasCloudBadge), Mode=OneWay}"
                                                                                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4,-4"
                                                                                                Width="12" Height="12" CornerRadius="6"
                                                                                                Background="{x:Bind CloudBadgeBrush, Mode=OneWay}"
                                                                                                IsHitTestVisible="False" x:Phase="1">
                                                                                            <FontIcon Glyph="{x:Bind CloudStateGlyph, Mode=OneWay}" FontSize="8"
                                                                                                      Foreground="{ThemeResource SpanTextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                        <!-- Git 뱃지 (동일 위치, Git 우선 — 위에 렌더링) -->
                                                                                        <Border Opacity="{x:Bind viewmodels:FileSystemViewModel.OpacityIfTrue(HasGitBadge), Mode=OneWay}"
                                                                                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4,-4"
                                                                                                Width="14" Height="14" CornerRadius="7"
                                                                                                Background="{x:Bind GitStatusBrush, Mode=OneWay}"
                                                                                                IsHitTestVisible="False" x:Phase="1">
                                                                                            <TextBlock Text="{x:Bind GitStatusText, Mode=OneWay}" FontSize="8" FontWeight="Bold"
                                                                                                       Foreground="{x:Bind GitBadgeTextBrush, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                       Margin="0,-1,0,0"/>
                                                                                        </Border>
                                                                                    </Grid>
                                                                                    <TextBlock Grid.Column="2" Text="{x:Bind TruncatedDisplayName, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontSize="13"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <TextBox Grid.Column="2" Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                             Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                                                                                             VerticalAlignment="Center" Padding="2" MinHeight="0" FontSize="13"
                                                                                             LostFocus="OnRenameTextBoxLostFocus" KeyDown="OnRenameTextBoxKeyDown"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </local:FileSystemItemTemplateSelector.FileTemplate>
                                                                    </local:FileSystemItemTemplateSelector>
                                                                </ListView.ItemTemplateSelector>
                                                            </ListView>
                                                            <!-- Loading indicator — visible while folder contents load -->
                                                            <ProgressRing IsActive="{x:Bind IsLoading, Mode=OneWay}"
                                                                          Width="20" Height="20"
                                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            <!-- Empty folder message -->
                                                            <StackPanel Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfTrue(IsEmpty), Mode=OneWay}"
                                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                        Spacing="4" Opacity="0.5">
                                                                <FontIcon Glyph="&#xE8B7;" FontSize="24"
                                                                          Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                                                          HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{x:Bind viewmodels:FolderViewModel.GetEmptyFolderText()}" FontSize="12"
                                                                           Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                                                           HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                            <!-- Error state -->
                                                            <StackPanel Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfTrue(HasError), Mode=OneWay}"
                                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                        Spacing="8" Opacity="0.7">
                                                                <FontIcon Glyph="{x:Bind ErrorIcon, Mode=OneWay}" FontSize="28"
                                                                          Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                                          HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{x:Bind ErrorMessage, Mode=OneWay}" FontSize="12"
                                                                           Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                                                           TextWrapping="Wrap" MaxWidth="200" TextAlignment="Center"
                                                                           HorizontalAlignment="Center"/>
                                                                <HyperlinkButton Content="{x:Bind viewmodels:FolderViewModel.GetRetryText()}" FontSize="11"
                                                                                 HorizontalAlignment="Center"
                                                                                 Click="OnRetryFolderLoad" Tag="{x:Bind}" />
                                                            </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <!-- Column edge shadow (depth) -->
                                                <Rectangle Grid.Column="1" Width="8" HorizontalAlignment="Left" Margin="-7,0,0,0"
                                                           Fill="{ThemeResource SpanColumnShadowBrush}" IsHitTestVisible="False"/>
                                                <!-- Column resize grip -->
                                                <Rectangle Grid.Column="1" Width="4" Fill="Transparent"
                                                           PointerEntered="OnColumnResizeGripPointerEntered"
                                                           PointerExited="OnColumnResizeGripPointerExited"
                                                           PointerPressed="OnColumnResizeGripPointerPressed"
                                                           PointerMoved="OnColumnResizeGripPointerMoved"
                                                           PointerReleased="OnColumnResizeGripPointerReleased"
                                                           DoubleTapped="OnColumnResizeGripDoubleTapped"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Home View (Right) -->
                            <views:HomeModeView x:Name="HomeViewRight"
                                                Visibility="{x:Bind IsHomeMode(ViewModel.RightViewMode), Mode=OneWay}"/>

                            <!-- Details View (Right) -->
                            <views:DetailsModeView x:Name="DetailsViewRight"
                                                   Visibility="{x:Bind IsDetailsMode(ViewModel.RightViewMode), Mode=OneWay}"/>

                            <!-- List View (Right) -->
                            <views:ListModeView x:Name="ListViewRight"
                                                Visibility="{x:Bind IsListMode(ViewModel.RightViewMode), Mode=OneWay}"/>

                            <!-- Icon View (Right) -->
                            <views:IconModeView x:Name="IconViewRight"
                                                Visibility="{x:Bind IsIconMode(ViewModel.RightViewMode), Mode=OneWay}"/>
                        </Grid>

                        <!-- Preview Splitter (Right) -->
                        <controls:GridSplitter Grid.Column="1" Width="2"
                            Background="Transparent"
                            Visibility="{x:Bind PreviewVisible(ViewModel.IsRightPreviewEnabled), Mode=OneWay}"/>

                        <!-- Preview Panel (Right) -->
                        <views:PreviewPanelView x:Name="RightPreviewPanel" Grid.Column="2"
                            MinWidth="320"
                            BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1,0,0,0"
                            Visibility="{x:Bind PreviewVisible(ViewModel.IsRightPreviewEnabled), Mode=OneWay}"/>
                    </Grid>

                    <!-- Git Status Bar (Right) -->
                    <Border x:Name="RightGitStatusBar" Grid.Row="2" Grid.ColumnSpan="3"
                            Height="28" Background="{ThemeResource SpanBgLayer2Brush}"
                            BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,1,0,0"
                            Visibility="Collapsed">
                        <Button x:Name="RightGitStatusButton"
                                Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="12,0" Height="28">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8AD;" FontSize="12"
                                          Foreground="{ThemeResource SpanAccentBrush}"/>
                                <TextBlock x:Name="RightGitBranch" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Rectangle Width="1" Height="14" Fill="{ThemeResource SpanBorderSubtleBrush}"
                                           Margin="4,0"/>
                                <TextBlock x:Name="RightGitStatus" FontSize="12" Opacity="0.8"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Flyout>
                                <Flyout Placement="TopEdgeAlignedRight">
                                    <StackPanel Width="320" Spacing="12" Padding="4">
                                        <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE8AD;" FontSize="14"
                                                          Foreground="{ThemeResource SpanAccentBrush}"/>
                                                <TextBlock x:Name="RightFlyoutBranch" FontSize="14"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <TextBlock x:Name="RightFlyoutStatus" FontSize="12" Opacity="0.8"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="RightFlyoutCommitsLabel" FontSize="11"
                                                       FontWeight="SemiBold" Opacity="0.6"/>
                                            <TextBlock x:Name="RightFlyoutCommits"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="RightFlyoutFilesLabel" FontSize="11"
                                                       FontWeight="SemiBold" Opacity="0.6"/>
                                            <ScrollViewer MaxHeight="200">
                                                <TextBlock x:Name="RightFlyoutFiles"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="11"/>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Border>
                </Grid>

                <!-- Split divider (RightPaneContainer의 Margin="1,0,0,0"으로 생긴 1px 갭에 배치) -->
                <Border Grid.Column="2" Width="1" HorizontalAlignment="Left" IsHitTestVisible="False"
                        Background="{ThemeResource SpanAccentDimBrush}"
                        Visibility="{x:Bind IsSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}"/>
            </Grid>

            <!-- Sidebar edge shadow removed: splitter alone provides sufficient separation -->
        </Grid>

        <!-- 4. Status Bar -->
        <Grid Grid.Row="3" AutomationProperties.AutomationId="StatusBar" Height="{StaticResource StatusBarHeight}" Background="{ThemeResource SpanBgMicaBrush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center" Margin="12,0">
                <StackPanel Orientation="Horizontal" Spacing="6"
                            Visibility="{x:Bind helpers:StatusBarHelper.ShowIfNotEmpty(ViewModel.StatusItemCountText), Mode=OneWay}">
                    <FontIcon Glyph="&#xE8A5;" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}"/>
                    <TextBlock AutomationProperties.AutomationId="TextBlock_ItemCount" Text="{x:Bind ViewModel.StatusItemCountText, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                </StackPanel>
                <Rectangle Width="1" Height="12" Fill="{ThemeResource SpanBorderSubtleBrush}"
                           Visibility="{x:Bind helpers:StatusBarHelper.ShowIfNotEmpty(ViewModel.StatusSelectionText), Mode=OneWay}"/>
                <TextBlock Text="{x:Bind ViewModel.StatusSelectionText, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource SpanTextSecondaryBrush}"
                           Visibility="{x:Bind helpers:StatusBarHelper.ShowIfNotEmpty(ViewModel.StatusSelectionText), Mode=OneWay}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,0,12,0">
                 <!-- Disk space info -->
                 <StackPanel Orientation="Horizontal" Spacing="6"
                             Visibility="{x:Bind helpers:StatusBarHelper.ShowIfNotEmpty(ViewModel.StatusDiskSpaceText), Mode=OneWay}">
                     <FontIcon Glyph="&#xEDA2;" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}"/>
                     <TextBlock AutomationProperties.AutomationId="TextBlock_DiskSpace" Text="{x:Bind ViewModel.StatusDiskSpaceText, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource SpanTextSecondaryBrush}" VerticalAlignment="Center"/>
                 </StackPanel>
                 <Rectangle Width="1" Height="12" Fill="{ThemeResource SpanBorderSubtleBrush}"
                            Visibility="{x:Bind helpers:StatusBarHelper.ShowIfNotEmpty(ViewModel.StatusDiskSpaceText), Mode=OneWay}"/>
                 <!-- View mode -->
                 <FontIcon Glyph="&#xE8A9;" FontSize="12" Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                 <TextBlock Text="{x:Bind ViewModel.StatusViewModeText, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource SpanTextSecondaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- File Operation Progress Panel (floating bottom-right, above content) -->
        <spancontrols:FileOperationProgressControl x:Name="FileOpProgressControl" AutomationProperties.AutomationId="FileOpProgress" Grid.Row="2"
                                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                    Canvas.ZIndex="100"
                                                    Margin="0,0,16,8"/>

        <!-- Help Overlay (Shift+? / F1) -->
        <Grid x:Name="HelpOverlay" AutomationProperties.AutomationId="HelpOverlay" Grid.RowSpan="4" Visibility="Collapsed"
              Canvas.ZIndex="200"
              Background="#80000000"
              PointerPressed="HelpOverlay_PointerPressed">
            <views:HelpFlyoutContent x:Name="HelpFlyoutContentControl" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Margin="40"/>
        </Grid>

        <!-- Toast Notification Overlay -->
        <Border x:Name="ToastOverlay" Grid.Row="2"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,16" Padding="16,10"
                Background="{ThemeResource SpanBgLayer1Brush}"
                BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1"
                CornerRadius="8" Opacity="0" IsHitTestVisible="False"
                RenderTransformOrigin="0.5,1">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate" Y="20"/>
            </Border.RenderTransform>
            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <FontIcon x:Name="ToastIcon" Glyph="&#xE73E;" FontSize="14"
                          Foreground="{ThemeResource SpanAccentBrush}"/>
                <TextBlock x:Name="ToastText" Text="" FontSize="13"
                           Foreground="{ThemeResource SpanTextPrimaryBrush}"
                           VerticalAlignment="Center" MaxWidth="500"
                           TextWrapping="WrapWholeWords"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
